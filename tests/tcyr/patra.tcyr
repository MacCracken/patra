# ── v0.11: Transactions ─────────────────────────────────────

fn test_transaction_commit() {
    test_group("tx commit");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE tx (id INT, val STR)");
    patra_begin(db);
    patra_exec(db, "INSERT INTO tx VALUES (1, 'a')");
    patra_exec(db, "INSERT INTO tx VALUES (2, 'b')");
    patra_commit(db);
    var rs = patra_query(db, "SELECT * FROM tx");
    assert_eq(patra_result_count(rs), 2, "committed 2");
    patra_result_free(rs);
    patra_close(db);
    db = patra_open(_tpath);
    rs = patra_query(db, "SELECT * FROM tx");
    assert_eq(patra_result_count(rs), 2, "persisted 2");
    patra_result_free(rs);
    patra_close(db);
}

fn test_transaction_rollback() {
    test_group("tx rollback");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE txr (id INT)");
    patra_exec(db, "INSERT INTO txr VALUES (1)");
    patra_begin(db);
    patra_exec(db, "INSERT INTO txr VALUES (2)");
    patra_exec(db, "INSERT INTO txr VALUES (3)");
    patra_rollback(db);
    var rs = patra_query(db, "SELECT * FROM txr");
    assert_eq(patra_result_count(rs), 1, "rolled back to 1");
    patra_result_free(rs);
    patra_close(db);
}
# ── Coverage: persistence ────────────────────────────────────

fn test_persistence() {
    test_group("persistence");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE p (id INT, val STR)");
    patra_exec(db, "INSERT INTO p VALUES (1, 'alpha')");
    patra_exec(db, "INSERT INTO p VALUES (2, 'beta')");
    patra_close(db);

    # Reopen and verify
    db = patra_open(_tpath);
    var rs = patra_query(db, "SELECT * FROM p");
    assert_eq(patra_result_count(rs), 2, "persisted 2");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "id 1");
    assert_streq(patra_result_get_str(rs, 0, 1), "alpha", "alpha");
    assert_eq(patra_result_get_int(rs, 1, 0), 2, "id 2");
    assert_streq(patra_result_get_str(rs, 1, 1), "beta", "beta");
    patra_result_free(rs);

    # Indexed lookup still works after reopen
    rs = patra_query(db, "SELECT * FROM p WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "index after reopen");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: page overflow ──────────────────────────────────

fn test_page_overflow() {
    test_group("page overflow");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE wide (id INT, a STR, b STR)");
    # Row size: 8 + 256 + 256 = 520 bytes. Page capacity: (4096-24)/520 = 7 rows.
    # Insert 60 rows to span ~9 pages.
    for (var i = 1; i <= 60; i = i + 1) {
        patra_exec(db, "INSERT INTO wide VALUES (1, 'aaaa', 'bbbb')");
    }
    var rs = patra_query(db, "SELECT * FROM wide");
    assert_eq(patra_result_count(rs), 60, "60 rows multi-page");
    patra_result_free(rs);

    # Delete half, verify
    patra_exec(db, "DELETE FROM wide WHERE id = 1 LIMIT 30");
    patra_close(db);
}

# ── Coverage: string edge cases ──────────────────────────────

fn test_string_edges() {
    test_group("string edges");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE se (id INT, s STR)");

    # Empty string
    patra_exec(db, "INSERT INTO se VALUES (1, '')");
    var rs = patra_query(db, "SELECT * FROM se WHERE id = 1");
    assert_eq(patra_result_count(rs), 1, "empty str");
    assert_streq(patra_result_get_str(rs, 0, 1), "", "empty val");
    patra_result_free(rs);

    # Max length (63 chars — last byte null)
    patra_exec(db, "INSERT INTO se VALUES (2, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa')");
    rs = patra_query(db, "SELECT * FROM se WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "max str");
    assert_eq(strlen(patra_result_get_str(rs, 0, 1)), 63, "63 chars");
    patra_result_free(rs);

    # WHERE on empty string
    rs = patra_query(db, "SELECT * FROM se WHERE s = ''");
    assert_eq(patra_result_count(rs), 1, "where empty");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: NEQ and STR comparisons ────────────────────────

fn test_neq_and_str_cmp() {
    test_group("neq and str cmp");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # NEQ on INT
    var rs = patra_query(db, "SELECT * FROM people WHERE age != 25");
    assert_eq(patra_result_count(rs), 3, "age!=25: 3");
    patra_result_free(rs);

    # NEQ on STR
    rs = patra_query(db, "SELECT * FROM people WHERE name != 'alice'");
    assert_eq(patra_result_count(rs), 4, "name!=alice: 4");
    patra_result_free(rs);

    # STR comparison operators
    rs = patra_query(db, "SELECT * FROM people WHERE name > 'carol'");
    assert_eq(patra_result_count(rs), 2, "name>carol: dave,eve");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name < 'carol'");
    assert_eq(patra_result_count(rs), 2, "name<carol: alice,bob");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name >= 'dave'");
    assert_eq(patra_result_count(rs), 2, "name>=dave: 2");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: multi-table isolation ──────────────────────────

fn test_multi_table_isolation() {
    test_group("multi table isolation");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t1 (id INT, x INT)");
    patra_exec(db, "CREATE TABLE t2 (id INT, y STR)");

    patra_exec(db, "INSERT INTO t1 VALUES (1, 100)");
    patra_exec(db, "INSERT INTO t1 VALUES (2, 200)");
    patra_exec(db, "INSERT INTO t2 VALUES (1, 'one')");

    # Changes to t1 don't affect t2
    patra_exec(db, "DELETE FROM t1 WHERE id = 1");
    var rs = patra_query(db, "SELECT * FROM t1");
    assert_eq(patra_result_count(rs), 1, "t1: 1 left");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM t2");
    assert_eq(patra_result_count(rs), 1, "t2: untouched");
    patra_result_free(rs);

    # Update one table
    patra_exec(db, "UPDATE t2 SET y = 'ONE' WHERE id = 1");
    rs = patra_query(db, "SELECT * FROM t1 WHERE id = 2");
    assert_eq(patra_result_get_int(rs, 0, 1), 200, "t1 unchanged");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: SQL edge cases ─────────────────────────────────

fn test_order_by_multi() {
    test_group("order by multi");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # ORDER BY age ASC, name ASC — age 25 has bob and dave
    var rs = patra_query(db, "SELECT * FROM people ORDER BY age, name");
    assert_eq(patra_result_get_int(rs, 0, 2), 25, "first age 25");
    assert_streq(patra_result_get_str(rs, 0, 1), "bob", "bob before dave");
    assert_streq(patra_result_get_str(rs, 1, 1), "dave", "dave second");
    assert_eq(patra_result_get_int(rs, 4, 2), 40, "last age 40");
    patra_result_free(rs);

    # ORDER BY age DESC, name ASC
    rs = patra_query(db, "SELECT * FROM people ORDER BY age DESC, name");
    assert_eq(patra_result_get_int(rs, 0, 2), 40, "desc first 40");
    assert_streq(patra_result_get_str(rs, 0, 1), "eve", "eve");
    # age 25 group at end, sorted by name ASC
    assert_streq(patra_result_get_str(rs, 3, 1), "bob", "age25 bob");
    assert_streq(patra_result_get_str(rs, 4, 1), "dave", "age25 dave");
    patra_result_free(rs);

    patra_close(db);
}

fn test_order_by_desc() {
    test_group("order by desc");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people ORDER BY age DESC");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_eq(patra_result_get_int(rs, 0, 2), 40, "first 40");
    assert_eq(patra_result_get_int(rs, 1, 2), 35, "second 35");
    assert_eq(patra_result_get_int(rs, 4, 2), 25, "last 25");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people ORDER BY name DESC");
    assert_streq(patra_result_get_str(rs, 0, 1), "eve", "desc first eve");
    assert_streq(patra_result_get_str(rs, 4, 1), "alice", "desc last alice");
    patra_result_free(rs);

    # ASC explicit
    rs = patra_query(db, "SELECT * FROM people ORDER BY age ASC");
    assert_eq(patra_result_get_int(rs, 0, 2), 25, "asc first 25");
    patra_result_free(rs);

    # DESC + LIMIT
    rs = patra_query(db, "SELECT * FROM people ORDER BY id DESC LIMIT 2");
    assert_eq(patra_result_count(rs), 2, "desc limit 2");
    assert_eq(patra_result_get_int(rs, 0, 0), 5, "desc id=5 first");
    assert_eq(patra_result_get_int(rs, 1, 0), 4, "desc id=4 second");
    patra_result_free(rs);

    patra_close(db);
}

fn test_sql_semicolons() {
    test_group("sql semicolons");
    # Trailing semicolons should not break parsing
    sql_tokenize("SELECT * FROM t;");
    assert_eq(sql_parse(), PATRA_OK, "trailing semi");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_SELECT, "select with semi");

    sql_tokenize("INSERT INTO t VALUES (1);");
    assert_eq(sql_parse(), PATRA_OK, "insert semi");

    sql_tokenize("DELETE FROM t WHERE id = 1;");
    assert_eq(sql_parse(), PATRA_OK, "delete semi");
}

# ── Coverage: JSONL special chars ────────────────────────────

fn test_jsonl_field_extract() {
    test_group("jsonl field extract");
    var line = "{\"action\": \"login\", \"count\": 42, \"name\": \"alice\"}";
    var llen = strlen(line);
    var slen = 0;

    # String extraction
    var sp = jsonl_get_str(line, llen, "action", 6, &slen);
    assert(sp != 0, "found action");
    assert_eq(slen, 5, "action len 5");
    assert(memeq(sp, "login", 5), "action=login");

    sp = jsonl_get_str(line, llen, "name", 4, &slen);
    assert(sp != 0, "found name");
    assert_eq(slen, 5, "name len 5");
    assert(memeq(sp, "alice", 5), "name=alice");

    # Integer extraction
    assert_eq(jsonl_get_int(line, llen, "count", 5), 42, "count=42");

    # Missing key
    assert_eq(jsonl_get_str(line, llen, "nope", 4, &slen), 0, "missing key");
    assert_eq(jsonl_get_int(line, llen, "nope", 4), 0, "missing int");
}

fn test_jsonl_special_chars() {
    test_group("jsonl special chars");
    jcleanup();
    var fd = jsonl_open(_jpath);

    var keys = fl_alloc(8);
    var vals = fl_alloc(8);
    var types = fl_alloc(8);
    store64(keys, "msg");
    store64(vals, "line1\nline2");
    store64(types, COL_STR);

    jsonl_append_obj(fd, keys, vals, types, 1);

    # Should be 1 line (newline escaped)
    assert_eq(jsonl_count(fd), 1, "escaped newline = 1 line");

    var lr = jsonl_read(fd);
    assert_eq(jsonl_lines_count(lr), 1, "read 1");
    jsonl_lines_free(lr);

    fl_free(keys);
    fl_free(vals);
    fl_free(types);
    jsonl_close(fd);
    jcleanup();
}

# ── v1.2: SELECT column list ─────────────────────────────────

fn test_select_col_single() {
    test_group("select col single");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT name FROM people");
    assert(rs != 0, "query ok");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_eq(patra_result_cols(rs), 1, "1 col");
    assert_streq(patra_result_col_name(rs, 0), "name", "col name");
    assert_streq(patra_result_get_str(rs, 0, 0), "alice", "row0");
    assert_streq(patra_result_get_str(rs, 4, 0), "eve", "row4");
    patra_result_free(rs);

    patra_close(db);
}

fn test_select_col_multi() {
    test_group("select col multi");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Project (name, age) — drop id, reorder
    var rs = patra_query(db, "SELECT name, age FROM people");
    assert_eq(patra_result_cols(rs), 2, "2 cols");
    assert_streq(patra_result_col_name(rs, 0), "name", "col0=name");
    assert_streq(patra_result_col_name(rs, 1), "age", "col1=age");
    assert_streq(patra_result_get_str(rs, 0, 0), "alice", "alice name");
    assert_eq(patra_result_get_int(rs, 0, 1), 30, "alice age");
    assert_streq(patra_result_get_str(rs, 1, 0), "bob", "bob name");
    assert_eq(patra_result_get_int(rs, 1, 1), 25, "bob age");
    patra_result_free(rs);

    # Reorder: age, id, name
    rs = patra_query(db, "SELECT age, id, name FROM people");
    assert_eq(patra_result_cols(rs), 3, "3 cols reordered");
    assert_eq(patra_result_get_int(rs, 0, 0), 30, "r0 age");
    assert_eq(patra_result_get_int(rs, 0, 1), 1, "r0 id");
    assert_streq(patra_result_get_str(rs, 0, 2), "alice", "r0 name");
    patra_result_free(rs);

    patra_close(db);
}

fn test_select_col_where_order_limit() {
    test_group("select col where order limit");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Projection with WHERE referencing non-projected col
    var rs = patra_query(db, "SELECT name FROM people WHERE age > 28");
    assert_eq(patra_result_count(rs), 3, "age>28: 3 rows");
    assert_eq(patra_result_cols(rs), 1, "1 col");
    patra_result_free(rs);

    # ORDER BY on non-projected col (sort runs before projection)
    rs = patra_query(db, "SELECT name FROM people ORDER BY age");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_streq(patra_result_get_str(rs, 4, 0), "eve", "last = eve (age 40)");
    patra_result_free(rs);

    # Projection + LIMIT
    rs = patra_query(db, "SELECT id, name FROM people LIMIT 2");
    assert_eq(patra_result_count(rs), 2, "limit 2");
    assert_eq(patra_result_cols(rs), 2, "2 cols");
    patra_result_free(rs);

    patra_close(db);
}

fn test_select_col_unknown() {
    test_group("select col unknown");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Unknown column — patra_query returns 0
    var rs = patra_query(db, "SELECT ghost FROM people");
    assert_eq(rs, 0, "unknown col returns 0");

    patra_close(db);
}

fn test_select_col_duplicate() {
    test_group("select col duplicate");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Duplicate column in projection is allowed (both emitted)
    var rs = patra_query(db, "SELECT id, id FROM people");
    assert_eq(patra_result_cols(rs), 2, "2 cols (both id)");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "r0 col0");
    assert_eq(patra_result_get_int(rs, 0, 1), 1, "r0 col1 (dup)");
    patra_result_free(rs);

    patra_close(db);
}

# ── v0.16: DROP TABLE ───────────────────────────────────────

fn test_drop_table() {
    test_group("drop table");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE d1 (id INT, val STR)");
    patra_exec(db, "INSERT INTO d1 VALUES (1, 'a')");
    patra_exec(db, "INSERT INTO d1 VALUES (2, 'b')");

    # Verify data exists
    var rs = patra_query(db, "SELECT * FROM d1");
    assert_eq(patra_result_count(rs), 2, "2 rows before drop");
    patra_result_free(rs);

    # Drop it
    var r = patra_exec(db, "DROP TABLE d1");
    assert_eq(r, PATRA_OK, "drop ok");

    # Query on dropped table should fail (returns 0)
    rs = patra_query(db, "SELECT * FROM d1");
    assert_eq(rs, 0, "query after drop null");

    # Insert should fail
    r = patra_exec(db, "INSERT INTO d1 VALUES (3, 'c')");
    assert_eq(r, PATRA_ERR_NOTFOUND, "insert after drop");

    # Drop missing table
    r = patra_exec(db, "DROP TABLE ghost");
    assert_eq(r, PATRA_ERR_NOTFOUND, "drop missing");

    patra_close(db);
}

fn test_drop_table_multi() {
    test_group("drop table multi");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t1 (id INT)");
    patra_exec(db, "CREATE TABLE t2 (id INT)");
    patra_exec(db, "CREATE TABLE t3 (id INT)");
    patra_exec(db, "INSERT INTO t1 VALUES (1)");
    patra_exec(db, "INSERT INTO t2 VALUES (2)");
    patra_exec(db, "INSERT INTO t3 VALUES (3)");

    # Drop middle table
    var r = patra_exec(db, "DROP TABLE t2");
    assert_eq(r, PATRA_OK, "drop t2 ok");

    # t1 and t3 still work
    var rs = patra_query(db, "SELECT * FROM t1");
    assert_eq(patra_result_count(rs), 1, "t1 intact");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "t1 val");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM t3");
    assert_eq(patra_result_count(rs), 1, "t3 intact");
    assert_eq(patra_result_get_int(rs, 0, 0), 3, "t3 val");
    patra_result_free(rs);

    # t2 gone
    rs = patra_query(db, "SELECT * FROM t2");
    assert_eq(rs, 0, "t2 gone");

    patra_close(db);
}

fn test_drop_table_persistence() {
    test_group("drop table persist");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE dp (id INT)");
    patra_exec(db, "INSERT INTO dp VALUES (1)");
    patra_exec(db, "DROP TABLE dp");
    patra_close(db);

    # Reopen — table should still be gone
    db = patra_open(_tpath);
    var rs = patra_query(db, "SELECT * FROM dp");
    assert_eq(rs, 0, "gone after reopen");
    patra_close(db);
}

fn test_drop_parse_errors() {
    test_group("drop parse errors");
    # DROP without TABLE
    sql_tokenize("DROP");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "drop alone");

    # DROP TABLE without name
    sql_tokenize("DROP TABLE");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "drop table no name");
}

# ── v0.16: WAL overflow ────────────────────────────────────

fn test_wal_overflow() {
    test_group("wal overflow");
    cleanup();
    var db = patra_open(_tpath);

    # Create a table with many columns to make rows large
    patra_exec(db, "CREATE TABLE wo (id INT, a STR, b STR, c STR)");

    # Start explicit transaction
    patra_begin(db);

    # Insert many rows to force many page writes
    # Each STR is 256 bytes, row = 8 + 256*3 = 776 bytes
    # Page fits ~5 rows (776*5 = 3880 < 4072 available)
    # 64 pages * 5 rows = 320 rows to fill WAL
    # We need > 64 unique page writes to trigger overflow
    var i = 0;
    while (i < 400) {
        patra_exec(db, "INSERT INTO wo VALUES (1, 'x', 'y', 'z')");
        i = i + 1;
    }

    # Commit returns PATRA_ERR_FULL to signal WAL overflow
    var r = patra_commit(db);
    assert_eq(r, PATRA_ERR_FULL, "commit reports overflow");

    # Data was still committed (just not crash-safe beyond 64 pages)
    var rs = patra_query(db, "SELECT COUNT(*) FROM wo");
    assert(patra_result_get_int(rs, 0, 0) > 0, "data committed");
    patra_result_free(rs);

    patra_close(db);
}

# ── v0.17: Hardening ────────────────────────────────────────

fn test_update_indexed_col() {
    test_group("update indexed col");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # id is the auto-indexed column. Change alice's id from 1 to 100.
    var r = patra_exec(db, "UPDATE people SET id = 100 WHERE name = 'alice'");
    assert_eq(r, PATRA_OK, "update id ok");

    # Old id should not find alice
    var rs = patra_query(db, "SELECT * FROM people WHERE id = 1");
    assert_eq(patra_result_count(rs), 0, "old id=1 gone");
    patra_result_free(rs);

    # New id should find alice via index
    rs = patra_query(db, "SELECT * FROM people WHERE id = 100");
    assert_eq(patra_result_count(rs), 1, "new id=100");
    assert_streq(patra_result_get_str(rs, 0, 1), "alice", "still alice");
    patra_result_free(rs);

    # Other rows unaffected
    rs = patra_query(db, "SELECT * FROM people WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "bob intact");
    patra_result_free(rs);

    # Range query still works
    rs = patra_query(db, "SELECT * FROM people WHERE id >= 3 AND id <= 5");
    assert_eq(patra_result_count(rs), 3, "range 3-5 intact");
    patra_result_free(rs);

    patra_close(db);
}

fn test_drop_recreate() {
    test_group("drop recreate");
    cleanup();
    var db = patra_open(_tpath);

    # Create, populate, drop
    patra_exec(db, "CREATE TABLE reuse (id INT, val STR)");
    patra_exec(db, "INSERT INTO reuse VALUES (1, 'old')");
    patra_exec(db, "DROP TABLE reuse");

    # Recreate with same name, different schema
    var r = patra_exec(db, "CREATE TABLE reuse (x INT, y INT)");
    assert_eq(r, PATRA_OK, "recreate ok");

    # Insert into new schema
    r = patra_exec(db, "INSERT INTO reuse VALUES (10, 20)");
    assert_eq(r, PATRA_OK, "insert new schema");

    var rs = patra_query(db, "SELECT * FROM reuse");
    assert_eq(patra_result_count(rs), 1, "1 row");
    assert_eq(patra_result_get_int(rs, 0, 0), 10, "x=10");
    assert_eq(patra_result_get_int(rs, 0, 1), 20, "y=20");
    patra_result_free(rs);

    # Old data is gone — only 1 row, not 2
    rs = patra_query(db, "SELECT COUNT(*) FROM reuse");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "count=1");
    patra_result_free(rs);

    patra_close(db);
}

fn test_tx_rollback_persistence() {
    test_group("tx rollback persist");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE txp (id INT, val STR)");
    patra_exec(db, "INSERT INTO txp VALUES (1, 'keep')");

    # Begin tx, insert more, rollback
    patra_begin(db);
    patra_exec(db, "INSERT INTO txp VALUES (2, 'discard')");
    patra_exec(db, "INSERT INTO txp VALUES (3, 'discard')");
    patra_rollback(db);

    # Close and reopen
    patra_close(db);
    db = patra_open(_tpath);

    # Only the pre-tx row should survive
    var rs = patra_query(db, "SELECT * FROM txp");
    assert_eq(patra_result_count(rs), 1, "1 row after reopen");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "id=1 kept");
    assert_streq(patra_result_get_str(rs, 0, 1), "keep", "val=keep");
    patra_result_free(rs);

    patra_close(db);
}

fn test_multipage_indexed() {
    test_group("multipage indexed");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE mp (id INT, name STR)");

    # Row = 8 + 256 = 264 bytes. Page capacity = (4096-24)/264 = 15 rows.
    # Insert 50 rows to span 4 pages.
    var i = 1;
    while (i <= 50) {
        patra_exec(db, "INSERT INTO mp VALUES (1, 'row')");
        i = i + 1;
    }

    # Full scan
    var rs = patra_query(db, "SELECT COUNT(*) FROM mp");
    assert_eq(patra_result_get_int(rs, 0, 0), 50, "count=50");
    patra_result_free(rs);

    # Index query (all have id=1)
    rs = patra_query(db, "SELECT * FROM mp WHERE id = 1");
    assert_eq(patra_result_count(rs), 50, "indexed all 50");
    patra_result_free(rs);

    # Range that matches nothing
    rs = patra_query(db, "SELECT * FROM mp WHERE id > 1");
    assert_eq(patra_result_count(rs), 0, "id>1 = 0");
    patra_result_free(rs);

    patra_close(db);
}

