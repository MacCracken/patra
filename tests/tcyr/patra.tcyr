# patra.tcyr — Patra test suite (v0.1 + v0.2)

include "src/lib.cyr"
include "lib/assert.cyr"

var _tpath = "/tmp/patra_test.patra";

fn cleanup() { syscall(SYS_UNLINK, _tpath); }

# ── v0.1: Header ────────────────────────────────────────────

fn test_header() {
    test_group("header");
    var buf = fl_alloc(PAGE_SIZE);
    patra_hdr_init(buf);
    assert_eq(load32(buf + HDR_MAGIC), PATRA_MAGIC, "magic");
    assert_eq(load32(buf + HDR_VER), PATRA_VER, "version");
    assert_eq(load64(buf + HDR_PGCOUNT), 1, "page count");
    assert_eq(load64(buf + HDR_TBLCOUNT), 0, "table count");
    assert_eq(patra_hdr_verify(buf), PATRA_OK, "verify ok");
    store32(buf + HDR_MAGIC, 0);
    assert_eq(patra_hdr_verify(buf), PATRA_ERR_MAGIC, "verify bad magic");
    fl_free(buf);
}

# ── v0.1: File create ───────────────────────────────────────

fn test_file_create() {
    test_group("file create");
    cleanup();
    var fd = _pt_file_create(_tpath);
    assert(fd >= 0, "create fd");
    var buf = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, buf);
    assert_eq(patra_hdr_verify(buf), PATRA_OK, "header valid");
    fl_free(buf);
    syscall(SYS_CLOSE, fd);
}

# ── v0.1: Page alloc / free ─────────────────────────────────

fn test_page_alloc() {
    test_group("page alloc");
    cleanup();
    var fd = _pt_file_create(_tpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);
    var p0 = page_alloc(fd, hdr);
    assert_eq(p0, 1, "first page 1");
    var p1 = page_alloc(fd, hdr);
    assert_eq(p1, 2, "second page 2");
    page_free(fd, hdr, p1);
    var p2 = page_alloc(fd, hdr);
    assert_eq(p2, 2, "reused freed page");
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
}

# ── v0.1: Page read / write ─────────────────────────────────

fn test_page_rw() {
    test_group("page read write");
    cleanup();
    var fd = _pt_file_create(_tpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);
    var pg = page_alloc(fd, hdr);
    var buf = fl_alloc(PAGE_SIZE);
    memset(buf, 0, PAGE_SIZE);
    store64(buf, 42);
    store64(buf + 8, 99);
    page_write(fd, pg, buf);
    memset(buf, 0, PAGE_SIZE);
    page_read(fd, pg, buf);
    assert_eq(load64(buf), 42, "read 42");
    assert_eq(load64(buf + 8), 99, "read 99");
    fl_free(buf);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
}

# ── v0.1: Row encoding ──────────────────────────────────────

fn test_row_encoding() {
    test_group("row encoding");
    var schema = fl_alloc(PAGE_SIZE);
    memset(schema, 0, PAGE_SIZE);
    store64(schema + SCH_NCOLS, 3);
    store64(schema + SCH_START + 0 * SCH_ENTRY_SZ + SCH_CTYPE, COL_INT);
    store64(schema + SCH_START + 1 * SCH_ENTRY_SZ + SCH_CTYPE, COL_STR);
    store64(schema + SCH_START + 2 * SCH_ENTRY_SZ + SCH_CTYPE, COL_INT);
    assert_eq(row_compute_size(schema, 3), 272, "row size 8+256+8");
    assert_eq(row_field_offset(schema, 3, 0), 0, "off col 0");
    assert_eq(row_field_offset(schema, 3, 1), 8, "off col 1");
    assert_eq(row_field_offset(schema, 3, 2), 264, "off col 2");
    var row = fl_alloc(272);
    memset(row, 0, 272);
    row_write_int(row, 0, 42);
    row_write_str(row, 8, "hello", 5);
    row_write_int(row, 264, 99);
    assert_eq(row_read_int(row, 0), 42, "int col 0");
    assert_eq(row_read_int(row, 264), 99, "int col 2");
    assert_streq(row_read_str(row, 8), "hello", "str col 1");
    fl_free(row);
    fl_free(schema);
}

# ── v0.1: SQL tokenizer ─────────────────────────────────────

fn test_tokenize() {
    test_group("tokenize");
    sql_tokenize("CREATE TABLE users (id INT, name STR)");
    assert_eq(_tok_type(0), TK_CREATE, "CREATE");
    assert_eq(_tok_type(1), TK_TABLE, "TABLE");
    assert_eq(_tok_type(2), TK_IDENT, "ident users");
    assert_eq(_tok_type(3), TK_LPAREN, "(");
    assert_eq(_tok_type(5), TK_KW_INT, "INT");
    assert_eq(_tok_type(8), TK_KW_STR, "STR");
    assert_eq(_sql_ntoks, 10, "10 tokens");
}

fn test_tokenize_v2() {
    test_group("tokenize v0.2");
    sql_tokenize("SELECT * FROM t WHERE id = 1 AND age > 25");
    assert_eq(_tok_type(4), TK_WHERE, "WHERE");
    assert_eq(_tok_type(6), TK_EQ, "=");
    assert_eq(_tok_type(8), TK_AND, "AND");
    assert_eq(_tok_type(10), TK_GT, ">");

    sql_tokenize("x != 1 AND y <= 2 AND z >= 3");
    assert_eq(_tok_type(1), TK_NEQ, "!=");
    assert_eq(_tok_type(5), TK_LTE, "<=");
    assert_eq(_tok_type(9), TK_GTE, ">=");

    sql_tokenize("UPDATE t SET x = 1");
    assert_eq(_tok_type(0), TK_UPDATE, "UPDATE");
    assert_eq(_tok_type(2), TK_SET, "SET");

    sql_tokenize("DELETE FROM t");
    assert_eq(_tok_type(0), TK_DELETE, "DELETE");

    sql_tokenize("ORDER BY x LIMIT 10");
    assert_eq(_tok_type(0), TK_ORDER, "ORDER");
    assert_eq(_tok_type(1), TK_BY, "BY");
    assert_eq(_tok_type(3), TK_LIMIT, "LIMIT");
}

# ── v0.1: SQL parser ────────────────────────────────────────

fn test_parse_create() {
    test_group("parse create");
    sql_tokenize("CREATE TABLE users (id INT, name STR)");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_CREATE, "stmt create");
    assert_eq(load64(_sql_pr + PR_COUNT), 2, "2 columns");
}

fn test_parse_insert() {
    test_group("parse insert");
    sql_tokenize("INSERT INTO users VALUES (1, 'alice')");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_INSERT, "stmt insert");
    assert_eq(load64(_sql_pr + PR_COUNT), 2, "2 values");
}

fn test_parse_select() {
    test_group("parse select");
    sql_tokenize("SELECT * FROM users");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_SELECT, "stmt select");
}

fn test_parse_case_insensitive() {
    test_group("case insensitive");
    sql_tokenize("create table Foo (id int, name str)");
    assert_eq(sql_parse(), PATRA_OK, "lowercase sql");
}

fn test_parse_bad_sql() {
    test_group("bad sql");
    sql_tokenize("BANANA");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "unknown stmt");
    sql_tokenize("SELECT id, FROM t");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "trailing comma");
    sql_tokenize("SELECT FROM t");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "no projection");
}

# ── v0.2: SQL parser extensions ──────────────────────────────

fn test_parse_select_where() {
    test_group("parse select where");
    sql_tokenize("SELECT * FROM t WHERE id = 1");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 1, "1 condition");

    sql_tokenize("SELECT * FROM t WHERE id > 1 AND age < 50");
    assert_eq(sql_parse(), PATRA_OK, "parse 2 conds");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 2, "2 conditions");
    assert_eq(load64(_sql_pr + PR_WHERE_JOIN), WH_AND, "join AND");

    sql_tokenize("SELECT * FROM t WHERE id = 1 OR id = 2");
    assert_eq(sql_parse(), PATRA_OK, "parse OR");
    assert_eq(load64(_sql_pr + PR_WHERE_JOIN), WH_OR, "join OR");
}

fn test_parse_orderby_limit() {
    test_group("parse orderby limit");
    sql_tokenize("SELECT * FROM t ORDER BY age");
    assert_eq(sql_parse(), PATRA_OK, "order by");
    assert_eq(load64(_sql_pr + PR_ORDERBY_N), 1, "has orderby");

    sql_tokenize("SELECT * FROM t LIMIT 5");
    assert_eq(sql_parse(), PATRA_OK, "limit");
    assert_eq(load64(_sql_pr + PR_LIMIT), 5, "limit 5");

    sql_tokenize("SELECT * FROM t WHERE id > 0 ORDER BY id LIMIT 3");
    assert_eq(sql_parse(), PATRA_OK, "where+order+limit");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 1, "1 where cond");
    assert_eq(load64(_sql_pr + PR_ORDERBY_N), 1, "has orderby");
    assert_eq(load64(_sql_pr + PR_LIMIT), 3, "limit 3");
}

fn test_parse_select_cols() {
    test_group("parse select cols");
    sql_tokenize("SELECT id FROM users");
    assert_eq(sql_parse(), PATRA_OK, "single col parse");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_SELECT, "stmt select");
    assert_eq(load64(_sql_pr + PR_PROJ_N), 1, "proj_n=1");

    sql_tokenize("SELECT id, name, age FROM users");
    assert_eq(sql_parse(), PATRA_OK, "multi col parse");
    assert_eq(load64(_sql_pr + PR_PROJ_N), 3, "proj_n=3");

    sql_tokenize("SELECT * FROM users");
    assert_eq(sql_parse(), PATRA_OK, "star parse");
    assert_eq(load64(_sql_pr + PR_PROJ_N), 0, "proj_n=0 for *");

    sql_tokenize("SELECT name FROM t WHERE id = 1 ORDER BY age LIMIT 5");
    assert_eq(sql_parse(), PATRA_OK, "col + where + order + limit");
    assert_eq(load64(_sql_pr + PR_PROJ_N), 1, "proj_n=1");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 1, "where=1");
    assert_eq(load64(_sql_pr + PR_ORDERBY_N), 1, "orderby=1");
    assert_eq(load64(_sql_pr + PR_LIMIT), 5, "limit=5");
}

fn test_parse_update() {
    test_group("parse update");
    sql_tokenize("UPDATE t SET age = 31 WHERE name = 'alice'");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_UPDATE, "stmt update");
    assert_eq(load64(_sql_pr + PR_COUNT), 1, "1 set pair");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 1, "1 where cond");
}

fn test_parse_delete() {
    test_group("parse delete");
    sql_tokenize("DELETE FROM t WHERE id = 1");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_DELETE, "stmt delete");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 1, "1 where cond");

    sql_tokenize("DELETE FROM t");
    assert_eq(sql_parse(), PATRA_OK, "delete all");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 0, "no where");
}

# ── v0.1: Full integration ──────────────────────────────────

fn test_create_insert_select() {
    test_group("create insert select");
    cleanup();
    var db = patra_open(_tpath);
    assert(db != 0, "open db");
    assert_eq(patra_exec(db, "CREATE TABLE t (id INT, val STR)"), PATRA_OK, "create");
    patra_exec(db, "INSERT INTO t VALUES (1, 'aaa')");
    patra_exec(db, "INSERT INTO t VALUES (2, 'bbb')");
    patra_exec(db, "INSERT INTO t VALUES (3, 'ccc')");
    var rs = patra_query(db, "SELECT * FROM t");
    assert(rs != 0, "query ok");
    assert_eq(patra_result_count(rs), 3, "3 rows");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "row0 id");
    assert_streq(patra_result_get_str(rs, 0, 1), "aaa", "row0 val");
    assert_eq(patra_result_get_int(rs, 2, 0), 3, "row2 id");
    patra_result_free(rs);
    patra_close(db);
}

fn test_errors() {
    test_group("errors");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE e (x INT)");
    assert_eq(patra_exec(db, "CREATE TABLE e (x INT)"), PATRA_ERR_EXISTS, "dup table");
    assert_eq(patra_exec(db, "INSERT INTO e VALUES (1, 2)"), PATRA_ERR_COLCOUNT, "too many");
    assert_eq(patra_exec(db, "INSERT INTO ghost VALUES (1)"), PATRA_ERR_NOTFOUND, "missing tbl");
    patra_close(db);
}

# ── v0.2: WHERE ──────────────────────────────────────────────

fn _setup_people(db) {
    patra_exec(db, "CREATE TABLE people (id INT, name STR, age INT)");
    patra_exec(db, "INSERT INTO people VALUES (1, 'alice', 30)");
    patra_exec(db, "INSERT INTO people VALUES (2, 'bob', 25)");
    patra_exec(db, "INSERT INTO people VALUES (3, 'carol', 35)");
    patra_exec(db, "INSERT INTO people VALUES (4, 'dave', 25)");
    patra_exec(db, "INSERT INTO people VALUES (5, 'eve', 40)");
    return 0;
}

fn test_where_eq() {
    test_group("where eq");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people WHERE id = 3");
    assert_eq(patra_result_count(rs), 1, "1 row");
    assert_eq(patra_result_get_int(rs, 0, 0), 3, "id=3");
    assert_streq(patra_result_get_str(rs, 0, 1), "carol", "name");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name = 'bob'");
    assert_eq(patra_result_count(rs), 1, "1 row str");
    assert_eq(patra_result_get_int(rs, 0, 0), 2, "bob id");
    patra_result_free(rs);
    patra_close(db);
}

fn test_where_cmp() {
    test_group("where comparisons");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people WHERE age > 30");
    assert_eq(patra_result_count(rs), 2, "age>30: 2 rows");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE age >= 35");
    assert_eq(patra_result_count(rs), 2, "age>=35: 2 rows");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE age < 30");
    assert_eq(patra_result_count(rs), 2, "age<30: 2 rows");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE id != 1");
    assert_eq(patra_result_count(rs), 4, "id!=1: 4 rows");
    patra_result_free(rs);
    patra_close(db);
}

fn test_where_and() {
    test_group("where AND");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people WHERE age >= 25 AND age <= 30");
    assert_eq(patra_result_count(rs), 3, "25<=age<=30: 3");
    patra_result_free(rs);
    patra_close(db);
}

fn test_where_or() {
    test_group("where OR");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people WHERE id = 1 OR id = 5");
    assert_eq(patra_result_count(rs), 2, "id=1 or 5: 2");
    patra_result_free(rs);
    patra_close(db);
}

fn test_where_no_match() {
    test_group("where no match");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people WHERE id = 99");
    assert_eq(patra_result_count(rs), 0, "no match");
    patra_result_free(rs);
    patra_close(db);
}

# ── v0.2: ORDER BY ───────────────────────────────────────────

fn test_order_by() {
    test_group("order by");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people ORDER BY age");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_eq(patra_result_get_int(rs, 0, 2), 25, "first age 25");
    assert_eq(patra_result_get_int(rs, 1, 2), 25, "second age 25");
    assert_eq(patra_result_get_int(rs, 2, 2), 30, "third age 30");
    assert_eq(patra_result_get_int(rs, 3, 2), 35, "fourth age 35");
    assert_eq(patra_result_get_int(rs, 4, 2), 40, "fifth age 40");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people ORDER BY name");
    assert_streq(patra_result_get_str(rs, 0, 1), "alice", "alpha first");
    assert_streq(patra_result_get_str(rs, 4, 1), "eve", "alpha last");
    patra_result_free(rs);
    patra_close(db);
}

# ── v0.2: LIMIT ──────────────────────────────────────────────

fn test_limit() {
    test_group("limit");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people LIMIT 2");
    assert_eq(patra_result_count(rs), 2, "limit 2");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people LIMIT 100");
    assert_eq(patra_result_count(rs), 5, "limit > rows");
    patra_result_free(rs);
    patra_close(db);
}

fn test_where_order_limit() {
    test_group("where + order + limit");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people WHERE age >= 25 ORDER BY age LIMIT 3");
    assert_eq(patra_result_count(rs), 3, "3 rows");
    assert_eq(patra_result_get_int(rs, 0, 2), 25, "first 25");
    assert_eq(patra_result_get_int(rs, 2, 2), 30, "third 30");
    patra_result_free(rs);
    patra_close(db);
}

# ── v0.2: UPDATE ─────────────────────────────────────────────

fn test_update() {
    test_group("update");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var r = patra_exec(db, "UPDATE people SET age = 31 WHERE name = 'alice'");
    assert_eq(r, PATRA_OK, "update ok");

    var rs = patra_query(db, "SELECT * FROM people WHERE name = 'alice'");
    assert_eq(patra_result_get_int(rs, 0, 2), 31, "alice age 31");
    patra_result_free(rs);

    # Update multiple rows
    patra_exec(db, "UPDATE people SET age = 99 WHERE age = 25");
    rs = patra_query(db, "SELECT * FROM people WHERE age = 99");
    assert_eq(patra_result_count(rs), 2, "2 updated to 99");
    patra_result_free(rs);

    # Update with no match
    patra_exec(db, "UPDATE people SET age = 0 WHERE id = 999");
    rs = patra_query(db, "SELECT * FROM people WHERE age = 0");
    assert_eq(patra_result_count(rs), 0, "no rows updated");
    patra_result_free(rs);
    patra_close(db);
}

fn test_update_multi_set() {
    test_group("update multi set");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    patra_exec(db, "UPDATE people SET name = 'ALICE', age = 99 WHERE id = 1");
    var rs = patra_query(db, "SELECT * FROM people WHERE id = 1");
    assert_streq(patra_result_get_str(rs, 0, 1), "ALICE", "name updated");
    assert_eq(patra_result_get_int(rs, 0, 2), 99, "age updated");
    patra_result_free(rs);
    patra_close(db);
}

# ── v0.2: DELETE ─────────────────────────────────────────────

fn test_delete() {
    test_group("delete");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var r = patra_exec(db, "DELETE FROM people WHERE id = 2");
    assert_eq(r, PATRA_OK, "delete ok");

    var rs = patra_query(db, "SELECT * FROM people");
    assert_eq(patra_result_count(rs), 4, "4 remaining");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE id = 2");
    assert_eq(patra_result_count(rs), 0, "bob gone");
    patra_result_free(rs);
    patra_close(db);
}

fn test_delete_multiple() {
    test_group("delete multiple");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    patra_exec(db, "DELETE FROM people WHERE age = 25");
    var rs = patra_query(db, "SELECT * FROM people");
    assert_eq(patra_result_count(rs), 3, "3 remaining");
    patra_result_free(rs);
    patra_close(db);
}

fn test_delete_all() {
    test_group("delete all");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    patra_exec(db, "DELETE FROM people");
    var rs = patra_query(db, "SELECT * FROM people");
    assert_eq(patra_result_count(rs), 0, "all deleted");
    patra_result_free(rs);
    patra_close(db);
}

fn test_delete_then_insert() {
    test_group("delete then insert");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    patra_exec(db, "DELETE FROM people WHERE id = 3");
    patra_exec(db, "INSERT INTO people VALUES (6, 'frank', 28)");
    var rs = patra_query(db, "SELECT * FROM people");
    assert_eq(patra_result_count(rs), 5, "5 after delete+insert");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name = 'frank'");
    assert_eq(patra_result_count(rs), 1, "frank exists");
    patra_result_free(rs);
    patra_close(db);
}

# ── v0.4: JSONL ──────────────────────────────────────────────

var _jpath = "/tmp/patra_test.jsonl";
fn jcleanup() { syscall(SYS_UNLINK, _jpath); return 0; }

fn test_json_build() {
    test_group("json build");
    var buf = fl_alloc(256);
    var keys = fl_alloc(24);
    var vals = fl_alloc(24);
    var types = fl_alloc(24);

    store64(keys, "id");
    store64(keys + 8, "name");
    store64(keys + 16, "age");
    store64(vals, 42);
    store64(vals + 8, "alice");
    store64(vals + 16, 30);
    store64(types, COL_INT);
    store64(types + 8, COL_STR);
    store64(types + 16, COL_INT);

    var len = json_build(buf, 256, keys, vals, types, 3);
    assert(len > 0, "len > 0");
    assert_streq(buf, "{\"id\": 42, \"name\": \"alice\", \"age\": 30}", "json fmt");

    fl_free(keys);
    fl_free(vals);
    fl_free(types);
    fl_free(buf);
}

fn test_json_escape() {
    test_group("json escape");
    var dst = fl_alloc(64);
    var n = _json_escape(dst, "a\"b\\c", 5);
    store8(dst + n, 0);
    assert_eq(n, 7, "escape len");
    assert_streq(dst, "a\\\"b\\\\c", "escaped");

    n = _json_escape(dst, "line\n", 5);
    store8(dst + n, 0);
    assert_streq(dst, "line\\n", "newline esc");
    fl_free(dst);
}

fn test_jsonl_append_read() {
    test_group("jsonl append read");
    jcleanup();
    var fd = jsonl_open(_jpath);
    assert(fd >= 0, "open");

    jsonl_append(fd, "{\"x\": 1}", 8);
    jsonl_append(fd, "{\"x\": 2}", 8);
    jsonl_append(fd, "{\"x\": 3}", 8);

    assert_eq(jsonl_count(fd), 3, "count 3");

    var lr = jsonl_read(fd);
    assert_eq(jsonl_lines_count(lr), 3, "read 3 lines");
    assert_eq(jsonl_lines_len(lr, 0), 8, "line0 len");

    # Verify first line content
    var p = jsonl_lines_get(lr, 0);
    assert(memeq(p, "{\"x\": 1}", 8), "line0 content");

    jsonl_lines_free(lr);
    jsonl_close(fd);
    jcleanup();
}

fn test_jsonl_append_obj() {
    test_group("jsonl append obj");
    jcleanup();
    var fd = jsonl_open(_jpath);

    var keys = fl_alloc(16);
    var vals = fl_alloc(16);
    var types = fl_alloc(16);
    store64(keys, "action");
    store64(keys + 8, "count");
    store64(vals, "login");
    store64(vals + 8, 5);
    store64(types, COL_STR);
    store64(types + 8, COL_INT);

    jsonl_append_obj(fd, keys, vals, types, 2);
    jsonl_append_obj(fd, keys, vals, types, 2);

    assert_eq(jsonl_count(fd), 2, "2 objects");

    var lr = jsonl_read(fd);
    assert_eq(jsonl_lines_count(lr), 2, "read 2");
    jsonl_lines_free(lr);

    fl_free(keys);
    fl_free(vals);
    fl_free(types);
    jsonl_close(fd);
    jcleanup();
}

fn test_jsonl_empty() {
    test_group("jsonl empty");
    jcleanup();
    var fd = jsonl_open(_jpath);
    assert_eq(jsonl_count(fd), 0, "empty count");
    var lr = jsonl_read(fd);
    assert_eq(jsonl_lines_count(lr), 0, "empty read");
    jsonl_lines_free(lr);
    jsonl_close(fd);
    jcleanup();
}

# ── v0.3: B-tree ─────────────────────────────────────────────

fn test_btree_basic() {
    test_group("btree basic");
    cleanup();
    var fd = _pt_file_create(_tpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);

    var root = btree_create(fd, hdr);
    root = btree_insert(fd, hdr, root, 10, 100);
    root = btree_insert(fd, hdr, root, 5, 50);
    root = btree_insert(fd, hdr, root, 20, 200);
    root = btree_insert(fd, hdr, root, 15, 150);

    var out = fl_alloc(64);
    assert_eq(btree_search(fd, hdr, root, 10, out, 8), 1, "find 10");
    assert_eq(load64(out), 100, "val 100");
    assert_eq(btree_search(fd, hdr, root, 5, out, 8), 1, "find 5");
    assert_eq(load64(out), 50, "val 50");
    assert_eq(btree_search(fd, hdr, root, 99, out, 8), 0, "miss 99");

    fl_free(out);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
}

fn test_btree_split() {
    test_group("btree split");
    cleanup();
    var fd = _pt_file_create(_tpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);

    var root = btree_create(fd, hdr);
    # Insert 100 keys to trigger leaf split
    for (var i = 0; i < 100; i = i + 1) {
        root = btree_insert(fd, hdr, root, i, i * 10);
    }

    # Verify all searchable
    var out = fl_alloc(64);
    var ok = 1;
    for (var i = 0; i < 100; i = i + 1) {
        var n = btree_search(fd, hdr, root, i, out, 8);
        if (n != 1) { ok = 0; }
        elif (load64(out) != i * 10) { ok = 0; }
    }
    assert(ok, "all 100 found");
    assert_eq(btree_search(fd, hdr, root, 999, out, 8), 0, "miss 999");

    fl_free(out);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
}

fn test_btree_range() {
    test_group("btree range");
    cleanup();
    var fd = _pt_file_create(_tpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);

    var root = btree_create(fd, hdr);
    for (var i = 0; i < 50; i = i + 1) {
        root = btree_insert(fd, hdr, root, i, i);
    }

    var out = fl_alloc(512);
    var n = _bt_range(fd, hdr, root, 10, 19, out, 64);
    assert_eq(n, 10, "range 10-19: 10");

    n = _bt_range(fd, hdr, root, 0, 49, out, 64);
    assert_eq(n, 50, "range 0-49: 50");

    n = _bt_range(fd, hdr, root, 100, 200, out, 64);
    assert_eq(n, 0, "range miss");

    fl_free(out);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
}

fn test_btree_duplicates() {
    test_group("btree duplicates");
    cleanup();
    var fd = _pt_file_create(_tpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);

    var root = btree_create(fd, hdr);
    root = btree_insert(fd, hdr, root, 5, 1);
    root = btree_insert(fd, hdr, root, 5, 2);
    root = btree_insert(fd, hdr, root, 5, 3);

    var out = fl_alloc(64);
    assert_eq(btree_search(fd, hdr, root, 5, out, 8), 3, "3 dups");

    fl_free(out);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
}

fn test_indexed_select() {
    test_group("indexed select");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # id is first INT column — should be indexed
    var rs = patra_query(db, "SELECT * FROM people WHERE id = 3");
    assert_eq(patra_result_count(rs), 1, "found by index");
    assert_streq(patra_result_get_str(rs, 0, 1), "carol", "correct row");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE id = 99");
    assert_eq(patra_result_count(rs), 0, "index miss");
    patra_result_free(rs);
    patra_close(db);
}

fn test_indexed_with_and() {
    test_group("indexed with AND");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Index finds id=2 candidates, AND filter checks age
    var rs = patra_query(db, "SELECT * FROM people WHERE id = 2 AND age = 25");
    assert_eq(patra_result_count(rs), 1, "and filter");
    assert_streq(patra_result_get_str(rs, 0, 1), "bob", "bob");
    patra_result_free(rs);

    # Index finds id=2, but age doesn't match
    rs = patra_query(db, "SELECT * FROM people WHERE id = 2 AND age = 99");
    assert_eq(patra_result_count(rs), 0, "and no match");
    patra_result_free(rs);
    patra_close(db);
}

fn test_no_index_str_table() {
