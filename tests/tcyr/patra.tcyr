    assert_eq(patra_exec(db, "VACUUM ghost"), PATRA_ERR_NOTFOUND, "unknown");
    patra_close(db);
}

# ── v1.3: LIKE operator ──────────────────────────────────────

fn test_parse_like() {
    test_group("parse like");
    sql_tokenize("SELECT * FROM t WHERE name LIKE 'a%'");
    assert_eq(sql_parse(), PATRA_OK, "like parse ok");
    assert_eq(load64(_sql_pr + PR_WHERE_N), 1, "1 cond");
    var cond = _sql_pr + PR_WHERE;
    assert_eq(load64(cond + WH_CMP_OP), CMP_LIKE, "op=LIKE");
    assert_eq(load64(cond + WH_VAL_TYPE), COL_STR, "str value");
}

fn test_like_prefix() {
    test_group("like prefix");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Prefix match: names starting with 'a' or 'b'
    var rs = patra_query(db, "SELECT * FROM people WHERE name LIKE 'a%'");
    assert_eq(patra_result_count(rs), 1, "alice");
    assert_streq(patra_result_get_str(rs, 0, 1), "alice", "matched alice");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name LIKE 'b%'");
    assert_eq(patra_result_count(rs), 1, "bob");
    patra_result_free(rs);

    # No match
    rs = patra_query(db, "SELECT * FROM people WHERE name LIKE 'z%'");
    assert_eq(patra_result_count(rs), 0, "no z");
    patra_result_free(rs);

    patra_close(db);
}

fn test_like_suffix() {
    test_group("like suffix");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Suffix match
    var rs = patra_query(db, "SELECT * FROM people WHERE name LIKE '%e'");
    # alice, carol, eve, dave? alice(a-l-i-c-e) ends 'e'; eve ends 'e'; dave ends 'e'; carol ends 'l'; bob ends 'b'
    assert_eq(patra_result_count(rs), 3, "alice, eve, dave");
    patra_result_free(rs);

    patra_close(db);
}

fn test_like_contains() {
    test_group("like contains");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # %a% → names containing 'a'
    var rs = patra_query(db, "SELECT * FROM people WHERE name LIKE '%a%'");
    # alice, carol, dave all contain 'a'; bob, eve don't
    assert_eq(patra_result_count(rs), 3, "3 contain a");
    patra_result_free(rs);

    # %l% → alice, carol
    rs = patra_query(db, "SELECT * FROM people WHERE name LIKE '%l%'");
    assert_eq(patra_result_count(rs), 2, "2 contain l");
    patra_result_free(rs);

    patra_close(db);
}

fn test_like_underscore() {
    test_group("like underscore");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # b_b → exactly 3 chars, starts with b, ends with b
    var rs = patra_query(db, "SELECT * FROM people WHERE name LIKE 'b_b'");
    assert_eq(patra_result_count(rs), 1, "matched bob");
    assert_streq(patra_result_get_str(rs, 0, 1), "bob", "is bob");
    patra_result_free(rs);

    # 3 chars, any
    rs = patra_query(db, "SELECT * FROM people WHERE name LIKE '___'");
    assert_eq(patra_result_count(rs), 2, "3-char names: bob, eve");
    patra_result_free(rs);

    patra_close(db);
}

fn test_like_literal() {
    test_group("like literal");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # No wildcards → exact equality semantics
    var rs = patra_query(db, "SELECT * FROM people WHERE name LIKE 'alice'");
    assert_eq(patra_result_count(rs), 1, "exact alice");
    patra_result_free(rs);

    # Empty pattern matches empty string only
    rs = patra_query(db, "SELECT * FROM people WHERE name LIKE ''");
    assert_eq(patra_result_count(rs), 0, "empty pattern no match");
    patra_result_free(rs);

    # % alone matches all
    rs = patra_query(db, "SELECT * FROM people WHERE name LIKE '%'");
    assert_eq(patra_result_count(rs), 5, "% matches all");
    patra_result_free(rs);

    patra_close(db);
}

# ── v1.2: SELECT column list ─────────────────────────────────

fn test_select_col_single() {
