# ── v0.11: Transactions ─────────────────────────────────────

fn test_transaction_commit() {
    test_group("tx commit");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE tx (id INT, val STR)");
    patra_begin(db);
    patra_exec(db, "INSERT INTO tx VALUES (1, 'a')");
    patra_exec(db, "INSERT INTO tx VALUES (2, 'b')");
    patra_commit(db);
    var rs = patra_query(db, "SELECT * FROM tx");
    assert_eq(patra_result_count(rs), 2, "committed 2");
    patra_result_free(rs);
    patra_close(db);
    db = patra_open(_tpath);
    rs = patra_query(db, "SELECT * FROM tx");
    assert_eq(patra_result_count(rs), 2, "persisted 2");
    patra_result_free(rs);
    patra_close(db);
}

fn test_transaction_rollback() {
    test_group("tx rollback");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE txr (id INT)");
    patra_exec(db, "INSERT INTO txr VALUES (1)");
    patra_begin(db);
    patra_exec(db, "INSERT INTO txr VALUES (2)");
    patra_exec(db, "INSERT INTO txr VALUES (3)");
    patra_rollback(db);
    var rs = patra_query(db, "SELECT * FROM txr");
    assert_eq(patra_result_count(rs), 1, "rolled back to 1");
    patra_result_free(rs);
    patra_close(db);
}
# ── Coverage: persistence ────────────────────────────────────

fn test_persistence() {
    test_group("persistence");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE p (id INT, val STR)");
    patra_exec(db, "INSERT INTO p VALUES (1, 'alpha')");
    patra_exec(db, "INSERT INTO p VALUES (2, 'beta')");
    patra_close(db);

    # Reopen and verify
    db = patra_open(_tpath);
    var rs = patra_query(db, "SELECT * FROM p");
    assert_eq(patra_result_count(rs), 2, "persisted 2");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "id 1");
    assert_streq(patra_result_get_str(rs, 0, 1), "alpha", "alpha");
    assert_eq(patra_result_get_int(rs, 1, 0), 2, "id 2");
    assert_streq(patra_result_get_str(rs, 1, 1), "beta", "beta");
    patra_result_free(rs);

    # Indexed lookup still works after reopen
    rs = patra_query(db, "SELECT * FROM p WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "index after reopen");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: page overflow ──────────────────────────────────

fn test_page_overflow() {
    test_group("page overflow");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE wide (id INT, a STR, b STR)");
    # Row size: 8 + 256 + 256 = 520 bytes. Page capacity: (4096-24)/520 = 7 rows.
    # Insert 60 rows to span ~9 pages.
    for (var i = 1; i <= 60; i = i + 1) {
        patra_exec(db, "INSERT INTO wide VALUES (1, 'aaaa', 'bbbb')");
    }
    var rs = patra_query(db, "SELECT * FROM wide");
    assert_eq(patra_result_count(rs), 60, "60 rows multi-page");
    patra_result_free(rs);

    # Delete half, verify
    patra_exec(db, "DELETE FROM wide WHERE id = 1 LIMIT 30");
    patra_close(db);
}

# ── Coverage: string edge cases ──────────────────────────────

fn test_string_edges() {
    test_group("string edges");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE se (id INT, s STR)");

    # Empty string
    patra_exec(db, "INSERT INTO se VALUES (1, '')");
    var rs = patra_query(db, "SELECT * FROM se WHERE id = 1");
    assert_eq(patra_result_count(rs), 1, "empty str");
    assert_streq(patra_result_get_str(rs, 0, 1), "", "empty val");
    patra_result_free(rs);

    # Max length (63 chars — last byte null)
    patra_exec(db, "INSERT INTO se VALUES (2, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa')");
    rs = patra_query(db, "SELECT * FROM se WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "max str");
    assert_eq(strlen(patra_result_get_str(rs, 0, 1)), 63, "63 chars");
    patra_result_free(rs);

    # WHERE on empty string
    rs = patra_query(db, "SELECT * FROM se WHERE s = ''");
    assert_eq(patra_result_count(rs), 1, "where empty");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: NEQ and STR comparisons ────────────────────────

fn test_neq_and_str_cmp() {
    test_group("neq and str cmp");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # NEQ on INT
    var rs = patra_query(db, "SELECT * FROM people WHERE age != 25");
    assert_eq(patra_result_count(rs), 3, "age!=25: 3");
    patra_result_free(rs);

    # NEQ on STR
    rs = patra_query(db, "SELECT * FROM people WHERE name != 'alice'");
    assert_eq(patra_result_count(rs), 4, "name!=alice: 4");
    patra_result_free(rs);

    # STR comparison operators
    rs = patra_query(db, "SELECT * FROM people WHERE name > 'carol'");
    assert_eq(patra_result_count(rs), 2, "name>carol: dave,eve");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name < 'carol'");
    assert_eq(patra_result_count(rs), 2, "name<carol: alice,bob");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people WHERE name >= 'dave'");
    assert_eq(patra_result_count(rs), 2, "name>=dave: 2");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: multi-table isolation ──────────────────────────

fn test_multi_table_isolation() {
    test_group("multi table isolation");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t1 (id INT, x INT)");
    patra_exec(db, "CREATE TABLE t2 (id INT, y STR)");

    patra_exec(db, "INSERT INTO t1 VALUES (1, 100)");
    patra_exec(db, "INSERT INTO t1 VALUES (2, 200)");
    patra_exec(db, "INSERT INTO t2 VALUES (1, 'one')");

    # Changes to t1 don't affect t2
    patra_exec(db, "DELETE FROM t1 WHERE id = 1");
    var rs = patra_query(db, "SELECT * FROM t1");
    assert_eq(patra_result_count(rs), 1, "t1: 1 left");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM t2");
    assert_eq(patra_result_count(rs), 1, "t2: untouched");
    patra_result_free(rs);

    # Update one table
    patra_exec(db, "UPDATE t2 SET y = 'ONE' WHERE id = 1");
    rs = patra_query(db, "SELECT * FROM t1 WHERE id = 2");
    assert_eq(patra_result_get_int(rs, 0, 1), 200, "t1 unchanged");
    patra_result_free(rs);

    patra_close(db);
}

# ── Coverage: SQL edge cases ─────────────────────────────────

fn test_order_by_multi() {
    test_group("order by multi");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # ORDER BY age ASC, name ASC — age 25 has bob and dave
    var rs = patra_query(db, "SELECT * FROM people ORDER BY age, name");
    assert_eq(patra_result_get_int(rs, 0, 2), 25, "first age 25");
    assert_streq(patra_result_get_str(rs, 0, 1), "bob", "bob before dave");
    assert_streq(patra_result_get_str(rs, 1, 1), "dave", "dave second");
    assert_eq(patra_result_get_int(rs, 4, 2), 40, "last age 40");
    patra_result_free(rs);

    # ORDER BY age DESC, name ASC
    rs = patra_query(db, "SELECT * FROM people ORDER BY age DESC, name");
    assert_eq(patra_result_get_int(rs, 0, 2), 40, "desc first 40");
    assert_streq(patra_result_get_str(rs, 0, 1), "eve", "eve");
    # age 25 group at end, sorted by name ASC
    assert_streq(patra_result_get_str(rs, 3, 1), "bob", "age25 bob");
    assert_streq(patra_result_get_str(rs, 4, 1), "dave", "age25 dave");
    patra_result_free(rs);

    patra_close(db);
}

fn test_order_by_desc() {
    test_group("order by desc");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT * FROM people ORDER BY age DESC");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_eq(patra_result_get_int(rs, 0, 2), 40, "first 40");
    assert_eq(patra_result_get_int(rs, 1, 2), 35, "second 35");
    assert_eq(patra_result_get_int(rs, 4, 2), 25, "last 25");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM people ORDER BY name DESC");
    assert_streq(patra_result_get_str(rs, 0, 1), "eve", "desc first eve");
    assert_streq(patra_result_get_str(rs, 4, 1), "alice", "desc last alice");
    patra_result_free(rs);

    # ASC explicit
    rs = patra_query(db, "SELECT * FROM people ORDER BY age ASC");
    assert_eq(patra_result_get_int(rs, 0, 2), 25, "asc first 25");
    patra_result_free(rs);

    # DESC + LIMIT
    rs = patra_query(db, "SELECT * FROM people ORDER BY id DESC LIMIT 2");
    assert_eq(patra_result_count(rs), 2, "desc limit 2");
    assert_eq(patra_result_get_int(rs, 0, 0), 5, "desc id=5 first");
    assert_eq(patra_result_get_int(rs, 1, 0), 4, "desc id=4 second");
    patra_result_free(rs);

    patra_close(db);
}

fn test_sql_semicolons() {
    test_group("sql semicolons");
    # Trailing semicolons should not break parsing
    sql_tokenize("SELECT * FROM t;");
    assert_eq(sql_parse(), PATRA_OK, "trailing semi");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_SELECT, "select with semi");

    sql_tokenize("INSERT INTO t VALUES (1);");
    assert_eq(sql_parse(), PATRA_OK, "insert semi");

    sql_tokenize("DELETE FROM t WHERE id = 1;");
    assert_eq(sql_parse(), PATRA_OK, "delete semi");
}

# ── Coverage: JSONL special chars ────────────────────────────

fn test_jsonl_field_extract() {
    test_group("jsonl field extract");
    var line = "{\"action\": \"login\", \"count\": 42, \"name\": \"alice\"}";
    var llen = strlen(line);
    var slen = 0;

    # String extraction
    var sp = jsonl_get_str(line, llen, "action", 6, &slen);
    assert(sp != 0, "found action");
    assert_eq(slen, 5, "action len 5");
    assert(memeq(sp, "login", 5), "action=login");

    sp = jsonl_get_str(line, llen, "name", 4, &slen);
    assert(sp != 0, "found name");
    assert_eq(slen, 5, "name len 5");
    assert(memeq(sp, "alice", 5), "name=alice");

    # Integer extraction
    assert_eq(jsonl_get_int(line, llen, "count", 5), 42, "count=42");

    # Missing key
    assert_eq(jsonl_get_str(line, llen, "nope", 4, &slen), 0, "missing key");
    assert_eq(jsonl_get_int(line, llen, "nope", 4), 0, "missing int");
}

fn test_jsonl_special_chars() {
    test_group("jsonl special chars");
    jcleanup();
    var fd = jsonl_open(_jpath);

    var keys = fl_alloc(8);
    var vals = fl_alloc(8);
    var types = fl_alloc(8);
    store64(keys, "msg");
    store64(vals, "line1\nline2");
    store64(types, COL_STR);

    jsonl_append_obj(fd, keys, vals, types, 1);

    # Should be 1 line (newline escaped)
    assert_eq(jsonl_count(fd), 1, "escaped newline = 1 line");

    var lr = jsonl_read(fd);
    assert_eq(jsonl_lines_count(lr), 1, "read 1");
    jsonl_lines_free(lr);

    fl_free(keys);
    fl_free(vals);
    fl_free(types);
    jsonl_close(fd);
    jcleanup();
}

# ── v1.5.3: audit P2 hardening + layout invariant ────────────

# Guards future parser growth against silently overrunning the 4096-byte
# `_sql_pr` buffer. Each statement type stores its per-item entries at
# PR_ITEMS, but only SELECT uses PR_AGG_* / PR_PROJ_N / PR_ORDERBY_COLS
# — so PR_ITEMS can legitimately overlap those ranges for CREATE / INSERT /
# UPDATE. The invariants we actually need:
#   - every PR_ITEMS write for any statement type fits within 4096
#   - SELECT's projection list (which uses PR_ITEMS) must stop before PR_AGG_TYPE
#   - PR_ORDERBY_COLS + OB zone ends before PR_WHERE
#   - PR_WHERE zone ends within 4096
# Audit §4.4 (static-assert-equivalent test for `_sql_pr` math).
fn test_parse_result_layout_invariant() {
    test_group("parse result layout");

    # Every statement's PR_ITEMS-based writes fit in the 4096 buffer
    assert(PR_ITEMS + MAX_COLS * CR_SZ <= 4096, "CREATE items in 4096");
    assert(PR_ITEMS + MAX_COLS * IR_SZ <= 4096, "INSERT items in 4096");
    assert(PR_ITEMS + MAX_COLS * SET_SZ <= 4096, "UPDATE set items in 4096");

    # SELECT projection list shares PR_ITEMS with other statement types but
    # only SELECT uses PR_AGG_TYPE/PR_PROJ_N — the projection must therefore
    # fit below PR_AGG_TYPE to avoid overwriting its own aggregate metadata.
    assert(PR_ITEMS + MAX_COLS * SEL_SZ <= PR_AGG_TYPE,
           "SELECT projection fits before PR_AGG_TYPE");

    # Aggregate metadata ordering
    assert(PR_AGG_COL_LEN + 8 <= PR_PROJ_N, "agg metadata before PR_PROJ_N");
    assert(PR_PROJ_N + 8 <= PR_ORDERBY_COLS, "PR_PROJ_N fits before order-by");

    # ORDER-BY columns zone holds OB_MAX × OB_SZ entries before PR_WHERE
    assert(PR_ORDERBY_COLS + OB_MAX * OB_SZ <= PR_WHERE,
           "ORDERBY_COLS fits before PR_WHERE");

    # WHERE condition zone holds WH_MAX × WH_ENTRY_SZ entries within 4096
    assert(PR_WHERE + WH_MAX * WH_ENTRY_SZ <= 4096,
           "PR_WHERE * WH_MAX fits in 4096");
}

# ── v1.5.2: audit P1 hardening ───────────────────────────────

# §4.2 #9 — JSON escape covers all control bytes 0x00–0x1F.
fn test_json_escape_control_chars() {
    test_group("json escape control chars");
    var dst = fl_alloc(256);
    var src = fl_alloc(32);

    # Insert each 0x00-0x1F byte and verify output
    # 0x00 (NUL) → [NUL]
    memset(src, 0, 32);
    store8(src, 0);
    var w = _json_escape(dst, src, 1);
    assert_eq(w, 6, "NUL emits 6 chars");
    assert_eq(load8(dst), 92, "leading backslash");
    assert_eq(load8(dst + 1), 117, "u");
    assert_eq(load8(dst + 2), 48, "0");
    assert_eq(load8(dst + 3), 48, "0");
    assert_eq(load8(dst + 4), 48, "0");
    assert_eq(load8(dst + 5), 48, "0");

    # 0x08 → \b
    store8(src, 8);
    w = _json_escape(dst, src, 1);
    assert_eq(w, 2, "\\b is 2 chars");
    assert_eq(load8(dst + 1), 98, "b");

    # 0x0C → \f
    store8(src, 12);
    w = _json_escape(dst, src, 1);
    assert_eq(w, 2, "\\f is 2 chars");
    assert_eq(load8(dst + 1), 102, "f");

    # 0x01 → [NUL]
    store8(src, 1);
    w = _json_escape(dst, src, 1);
    assert_eq(w, 6, "\\u0001 is 6 chars");
    assert_eq(load8(dst + 5), 49, "last hex = '1'");

    # 0x1F → [NUL]
    store8(src, 31);
    w = _json_escape(dst, src, 1);
    assert_eq(w, 6, "\\u001f is 6 chars");
    assert_eq(load8(dst + 4), 49, "hex hi = '1'");
    assert_eq(load8(dst + 5), 102, "hex lo = 'f'");

    # Printable byte 0x20 stays literal
    store8(src, 32);
    w = _json_escape(dst, src, 1);
    assert_eq(w, 1, "space is 1 char");
    assert_eq(load8(dst), 32, "space preserved");

    # High byte 0x80 stays literal (not mistakenly escaped)
    store8(src, 128);
    w = _json_escape(dst, src, 1);
    assert_eq(w, 1, "0x80 passes through");

    fl_free(src);
    fl_free(dst);
}

# §4.2 (new) — jsonl_get_int refuses overflow-inducing input.
fn test_jsonl_get_int_overflow() {
    test_group("jsonl_get_int overflow");
    # 25-digit value overflows i64; pre-1.5.2 silently wrapped.
    var line = "{\"priority\": 99999999999999999999}";
    var ll = strlen(line);
    var v = jsonl_get_int(line, ll, "priority", 8);
    assert_eq(v, 0, "25-digit overflow returns 0");

    # Normal value still works
    var line2 = "{\"priority\": 42}";
    v = jsonl_get_int(line2, strlen(line2), "priority", 8);
    assert_eq(v, 42, "42 still parses");

    # Exact cutoff: 922337203685477580 (MAX_I64/10) just fits (no overflow
    # because we check BEFORE the multiply; this value itself is legal).
    var line3 = "{\"x\": 922337203685477580}";
    v = jsonl_get_int(line3, strlen(line3), "x", 1);
    assert_eq(v, 922337203685477580, "cutoff value parses");

    # Any further digit overflows → returns 0
    var line4 = "{\"x\": 9223372036854775820}";
    v = jsonl_get_int(line4, strlen(line4), "x", 1);
    assert_eq(v, 0, "MAX+n overflow rejected");
}

# §4.2 #14 — O_NOFOLLOW refuses to open a symlinked DB path.
fn test_symlink_refused() {
    test_group("symlink refused");
    var target = "/tmp/patra_nofollow_real.patra";
    var link = "/tmp/patra_nofollow_link.patra";
    syscall(SYS_UNLINK, target);
    syscall(SYS_UNLINK, link);

    # Create a real db at target, then symlink link → target
    var db = patra_open(target);
    assert(db != 0, "real db open");
    patra_close(db);
    # SYS_SYMLINK = 88 on x86_64 Linux: symlink(target, linkpath)
    syscall(88, target, link);

    # Open via symlink must fail
    db = patra_open(link);
    assert_eq(db, 0, "open via symlink refused");

    syscall(SYS_UNLINK, link);
    syscall(SYS_UNLINK, target);
}

# §4.2 #12 — page_offset overflow returns sentinel; page_alloc via
# corrupted HDR_FREEHEAD does not wild-seek.
fn test_page_offset_overflow() {
    test_group("page_offset overflow");
    # Sane values
    assert_eq(page_offset(0), 4096, "pg 0 offset");
    assert_eq(page_offset(1), 8192, "pg 1 offset");

    # Overflow cap (> 2^50) returns -1
    assert(page_offset(1125899906842625) < 0, "just over cap rejected");
    assert(page_offset(0 - 5) < 0, "negative rejected");
}

# §2.9 — wal_commit issues fdatasync on the DB fd before unlink.
# Hard to test directly without an fsync instrumentation hook; sanity-check
# that a committed transaction survives close/reopen, which it must.
fn test_wal_commit_durable() {
    test_group("wal commit durable");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE wc (id INT, v STR)");
    patra_begin(db);
    patra_exec(db, "INSERT INTO wc VALUES (1, 'a')");
    patra_exec(db, "INSERT INTO wc VALUES (2, 'b')");
    var rc = patra_commit(db);
    assert_eq(rc, PATRA_OK, "commit ok");
    patra_close(db);

    db = patra_open(_tpath);
    var rs = patra_query(db, "SELECT * FROM wc");
    assert_eq(patra_result_count(rs), 2, "committed rows persist");
    patra_result_free(rs);
    patra_close(db);
}

# ── v1.5.1: audit-driven hardening ───────────────────────────

# §4.2 #10 — INSERT with too many values returns PATRA_ERR_COLCOUNT
# before trampling past PR_ITEMS.
fn test_insert_value_count_bounded() {
    test_group("insert value count bounded");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (x INT)");
    # 200 values into a 1-col table — must reject during parse
    var sql[4096];
    memcpy(&sql, "INSERT INTO t VALUES (", 22);
    var w = 22;
    for (var i = 0; i < 200; i = i + 1) {
        if (i > 0) { store8(&sql + w, 44); w = w + 1; store8(&sql + w, 32); w = w + 1; }
        store8(&sql + w, 49); w = w + 1;  # '1'
    }
    store8(&sql + w, 41); w = w + 1;  # ')'
    store8(&sql + w, 0);
    assert_eq(patra_exec(db, &sql), PATRA_ERR_COLCOUNT, "200-value insert rejected");
    patra_close(db);
}

# §4.2 #11 — WHERE with too many conditions returns an error.
fn test_where_condition_count_bounded() {
    test_group("where condition count bounded");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (x INT)");
    # 100 AND conditions — exceeds WH_MAX=32
    var sql[4096];
    memcpy(&sql, "SELECT * FROM t WHERE x = 1", 27);
    var w = 27;
    for (var i = 0; i < 100; i = i + 1) {
        memcpy(&sql + w, " AND x = 1", 10);
        w = w + 10;
    }
    store8(&sql + w, 0);
    # Beyond cap → parse fails and query returns null
    var rs = patra_query(db, &sql);
    assert_eq(rs, 0, "over-capped WHERE rejected");
    patra_close(db);
}

# §4.2 #7 (subset) — bare random-bytes WAL is refused, no silent replay.
fn test_wal_bad_magic_refused() {
    test_group("wal bad magic refused");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (x INT)");
    patra_exec(db, "INSERT INTO t VALUES (42)");
    patra_close(db);

    # Drop a junk .wal next to the DB
    var wpath = "/tmp/patra_test.patra.wal";
    var wfd = syscall(SYS_OPEN, wpath, 578, 420);
    var junk = fl_alloc(WAL_REC_SZ);
    memset(junk, 0xAA, WAL_REC_SZ);
    syscall(SYS_WRITE, wfd, junk, WAL_REC_SZ);
    syscall(SYS_CLOSE, wfd);
    fl_free(junk);

    # Reopen: wal_recover must refuse and leave the DB intact
    db = patra_open(_tpath);
    var rs = patra_query(db, "SELECT * FROM t");
    assert(rs != 0, "db intact after junk wal");
    assert_eq(patra_result_count(rs), 1, "row preserved");
    assert_eq(patra_result_get_int(rs, 0, 0), 42, "value preserved");
    patra_result_free(rs);
    patra_close(db);
    syscall(SYS_UNLINK, wpath);
}

# §4.2 (new) — valid WAL with a forged tail record (bad checksum) replays
# up to the bad record and stops.
fn test_wal_checksum_stops_replay() {
    test_group("wal checksum stops replay");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (x INT)");
    patra_exec(db, "INSERT INTO t VALUES (1)");
    patra_close(db);

    # Craft a minimal well-formed WAL header + one bad-checksum record
    var wpath = "/tmp/patra_test.patra.wal";
    var wfd = syscall(SYS_OPEN, wpath, 578, 420);
    var hdr = fl_alloc(WAL_HDR_SZ);
    store32(hdr, WAL_MAGIC);
    store32(hdr + 4, WAL_VER);
    syscall(SYS_WRITE, wfd, hdr, WAL_HDR_SZ);
    fl_free(hdr);
    # Forged record: claims to restore page 1 with zeros, checksum all zero
    var rec = fl_alloc(WAL_REC_SZ);
    memset(rec, 0, WAL_REC_SZ);
    store64(rec, 1);  # page 1
    syscall(SYS_WRITE, wfd, rec, WAL_REC_SZ);
    fl_free(rec);
    syscall(SYS_CLOSE, wfd);

    # Reopen: header is valid, but the record's checksum (0) will not match
    # _wal_hash(1, zeros). Replay must stop before overwriting page 1.
    db = patra_open(_tpath);
    var rs = patra_query(db, "SELECT * FROM t");
    assert(rs != 0, "db intact");
    assert_eq(patra_result_count(rs), 1, "row preserved");
    patra_result_free(rs);
    patra_close(db);
}

# §4.2 (new) — patra_hdr_verify rejects over-cap table count.
fn test_hdr_verify_bad_tblcount() {
    test_group("hdr verify bad tblcount");
    var buf = fl_alloc(PAGE_SIZE);
    patra_hdr_init(buf);
    store64(buf + HDR_TBLCOUNT, 1000);  # > MAX_TABLES (63)
    assert_eq(patra_hdr_verify(buf), PATRA_ERR_PAGE, "over-max tblcount rejected");

    # FREEHEAD past PGCOUNT also rejected
    patra_hdr_init(buf);
    store64(buf + HDR_PGCOUNT, 10);
    store64(buf + HDR_FREEHEAD, 99);
    assert_eq(patra_hdr_verify(buf), PATRA_ERR_PAGE, "out-of-range freehead rejected");

    # Zero pgcount rejected
    patra_hdr_init(buf);
    store64(buf + HDR_PGCOUNT, 0);
    assert_eq(patra_hdr_verify(buf), PATRA_ERR_PAGE, "zero pgcount rejected");

    # Wrong version rejected
    patra_hdr_init(buf);
    store32(buf + HDR_VER, 999);
    assert_eq(patra_hdr_verify(buf), PATRA_ERR_MAGIC, "bad version rejected");

    fl_free(buf);
}

# §4.2 #6 (subset) — malformed B-tree child pointer caught by page_read_checked.
# We fabricate a root leaf that claims to be internal with a child pointing
# past end-of-file; the indexed SELECT must not crash.
fn test_btree_bad_child_pointer() {
    test_group("btree bad child pointer");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (id INT, x INT)");
    patra_exec(db, "INSERT INTO t VALUES (1, 10)");
    patra_exec(db, "INSERT INTO t VALUES (2, 20)");

    # Locate the B-tree root and corrupt it: flip leaf→internal and set
    # child 0 = huge out-of-range page number.
    var hdr = _db_hdr(db);
    var fd = _db_fd(db);
    var entry = _tbl_entry(hdr, 0);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = fl_alloc(PAGE_SIZE);
    page_read(fd, spg, schema);
    var ir = load64(schema + SCH_IDX_ROOT);
    fl_free(schema);

    var buf = fl_alloc(PAGE_SIZE);
    page_read(fd, ir, buf);
    store64(buf + BT_LEAF, 0);                         # claim internal
    store64(buf + BT_NKEYS, 1);
    store64(buf + BT_VALS, 999999);                    # bogus child 0
    store64(buf + BT_VALS + 8, 999999);                # bogus child 1
    page_write(fd, ir, buf);
    fl_free(buf);

    # Query must return without crashing (bounds check on page_read intercepts
    # the bogus child pointer; depth cap also provides backstop).
    var rs = patra_query(db, "SELECT * FROM t WHERE id = 1");
    # Don't assert a specific count — the tree is deliberately broken.
    # We only assert patra_query returned without crashing.
    if (rs != 0) { patra_result_free(rs); }
    assert(1, "survived bad child pointer");

    patra_close(db);
}

# ── v1.5: B-tree full-tree page reclaim ──────────────────────

fn _free_list_len(db) {
    var hdr = _db_hdr(db);
    var fd = _db_fd(db);
    var cnt = 0;
    var cur = load64(hdr + HDR_FREEHEAD);
    var buf = fl_alloc(PAGE_SIZE);
    while (cur != 0) {
        page_read(fd, cur, buf);
        cur = load64(buf + FP_NEXT);
        cnt = cnt + 1;
    }
    fl_free(buf);
    return cnt;
}

fn test_btree_page_reclaim_drop() {
    test_group("btree reclaim on drop");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE r (id INT, name STR)");

    # 300 unique keys force the order-64 tree past one leaf
    # (split at 32, so ~10 leaves + at least one internal level)
    var _rsql[64];
    for (var ri = 0; ri < 300; ri = ri + 1) {
        var _rargs = vec_new();
        vec_push(_rargs, ri);
        fmt_sprintf(&_rsql, 64, "INSERT INTO r VALUES (%d, 'x')", _rargs);
        patra_exec(db, &_rsql);
    }

    var free_before = _free_list_len(db);
    patra_exec(db, "DROP TABLE r");
    var free_after = _free_list_len(db);

    # Pre-1.5.0: tbl_drop only freed the B-tree root → delta dominated by
    # a handful of data pages. Post-1.5.0: every internal + leaf page is
    # reclaimed too. For 300 keys we expect well over 5 B-tree pages alone.
    assert(free_after - free_before >= 5, "multi-level b-tree pages reclaimed");

    patra_close(db);
}

fn test_btree_page_reclaim_alter_add() {
    test_group("btree reclaim on alter add");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE a (id INT, x INT)");
    var _asql[64];
    for (var ai = 0; ai < 200; ai = ai + 1) {
        var _aargs = vec_new();
        vec_push(_aargs, ai);
        fmt_sprintf(&_asql, 64, "INSERT INTO a VALUES (%d, 0)", _aargs);
        patra_exec(db, &_asql);
    }

    # Record free list depth before ALTER. With 200 inserts pgcount has grown;
    # free list is typically empty at this point (no drops/vacuums yet).
    var hdr = _db_hdr(db);
    var fd = _db_fd(db);
    var pgcount_before = load64(hdr + HDR_PGCOUNT);

    # ALTER ADD INT has minimal row-size impact (8 bytes) — the new B-tree
    # rebuild's page demand is almost identical to the old tree's freed pages.
    patra_exec(db, "ALTER TABLE a ADD COLUMN y INT");

    var pgcount_after = load64(hdr + HDR_PGCOUNT);

    # Pre-1.5.0: tbl_drop-style single-root free leaked ~7 internal+leaf
    # B-tree pages, forcing the rebuild to extend the file by that amount
    # plus at least 1 data page. Post-1.5.0: whole-tree reclaim feeds the
    # rebuild entirely from the free list; file growth should be small.
    assert(pgcount_after - pgcount_before <= 3, "alter add reuses freed pages");

    # Sanity: queries still correct
    var rs = patra_query(db, "SELECT * FROM a WHERE id = 100");
    assert_eq(patra_result_count(rs), 1, "indexed query post-alter-add");
    patra_result_free(rs);

    patra_close(db);
}

# ── v1.4: ALTER TABLE ────────────────────────────────────────

fn test_parse_alter() {
    test_group("parse alter");
    sql_tokenize("ALTER TABLE t ADD COLUMN age INT");
    assert_eq(sql_parse(), PATRA_OK, "add col parse");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_ALTER_ADD, "stmt=ADD");

    sql_tokenize("ALTER TABLE t RENAME TO people");
    assert_eq(sql_parse(), PATRA_OK, "rename to parse");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_ALTER_RENAME_TBL, "stmt=RENAME_TBL");

    sql_tokenize("ALTER TABLE t RENAME COLUMN id TO pk");
    assert_eq(sql_parse(), PATRA_OK, "rename col parse");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_ALTER_RENAME_COL, "stmt=RENAME_COL");

    sql_tokenize("ALTER TABLE t ADD age INT");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "missing COLUMN keyword");

    sql_tokenize("ALTER TABLE t DROP COLUMN id");
    assert_eq(sql_parse(), PATRA_OK, "drop col parse");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_ALTER_DROP_COL, "stmt=DROP_COL");

    sql_tokenize("ALTER TABLE t DROP id");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "missing COLUMN keyword");
}

fn test_alter_drop_middle() {
    test_group("alter drop middle col");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE m (id INT, name STR, age INT)");
    patra_exec(db, "INSERT INTO m VALUES (1, 'alice', 30)");
    patra_exec(db, "INSERT INTO m VALUES (2, 'bob', 25)");
    patra_exec(db, "INSERT INTO m VALUES (3, 'carol', 35)");

    assert_eq(patra_exec(db, "ALTER TABLE m DROP COLUMN name"), PATRA_OK, "drop middle");

    var rs = patra_query(db, "SELECT * FROM m");
    assert_eq(patra_result_cols(rs), 2, "2 cols remain");
    assert_eq(patra_result_count(rs), 3, "3 rows preserved");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "r0 id");
    assert_eq(patra_result_get_int(rs, 0, 1), 30, "r0 age (shifted left)");
    assert_eq(patra_result_get_int(rs, 2, 1), 35, "r2 age");
    assert_streq(patra_result_col_name(rs, 1), "age", "col1 name");
    patra_result_free(rs);

    # Index on id still resolves (indexed col precedes dropped col)
    rs = patra_query(db, "SELECT * FROM m WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "index still works");
    assert_eq(patra_result_get_int(rs, 0, 1), 25, "bob age");
    patra_result_free(rs);

    patra_close(db);
}

fn test_alter_drop_indexed_col() {
    test_group("alter drop indexed col");
    cleanup();
    var db = patra_open(_tpath);
    # id is auto-indexed (first INT col)
    patra_exec(db, "CREATE TABLE di (id INT, name STR, age INT)");
    patra_exec(db, "INSERT INTO di VALUES (1, 'a', 10)");
    patra_exec(db, "INSERT INTO di VALUES (2, 'b', 20)");

    # Drop the indexed column → index torn down
    assert_eq(patra_exec(db, "ALTER TABLE di DROP COLUMN id"), PATRA_OK, "drop indexed");

    var rs = patra_query(db, "SELECT * FROM di");
    assert_eq(patra_result_cols(rs), 2, "2 cols");
    assert_streq(patra_result_col_name(rs, 0), "name", "col0 now name");
    assert_streq(patra_result_get_str(rs, 0, 0), "a", "r0 name");
    assert_eq(patra_result_get_int(rs, 0, 1), 10, "r0 age");
    patra_result_free(rs);

    # age is INT but not indexed (index was torn down and first remaining INT col
    # is age but we don't auto-reindex). Query still works via scan.
    rs = patra_query(db, "SELECT * FROM di WHERE age = 20");
    assert_eq(patra_result_count(rs), 1, "scan works");
    patra_result_free(rs);

    # Can re-index explicitly
    assert_eq(patra_exec(db, "CREATE INDEX ON di (age)"), PATRA_OK, "new index ok");
    rs = patra_query(db, "SELECT * FROM di WHERE age = 10");
    assert_eq(patra_result_count(rs), 1, "new indexed query ok");
    patra_result_free(rs);

    patra_close(db);
}

fn test_alter_drop_before_indexed() {
    test_group("alter drop before indexed col");
    cleanup();
    var db = patra_open(_tpath);
    # Create with STR first so indexed col is not at 0. Then CREATE INDEX on id.
    patra_exec(db, "CREATE TABLE bi (tag STR, id INT, age INT)");
    patra_exec(db, "CREATE INDEX ON bi (id)");
    patra_exec(db, "INSERT INTO bi VALUES ('x', 1, 10)");
    patra_exec(db, "INSERT INTO bi VALUES ('y', 2, 20)");
    patra_exec(db, "INSERT INTO bi VALUES ('z', 3, 30)");

    # Drop tag (col 0). Indexed col id shifts from 1 → 0.
    assert_eq(patra_exec(db, "ALTER TABLE bi DROP COLUMN tag"), PATRA_OK, "drop col0");

    # Indexed query on id still works with the rebuilt index at its new position
    var rs = patra_query(db, "SELECT * FROM bi WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "indexed query post-shift");
    assert_eq(patra_result_get_int(rs, 0, 0), 2, "id=2");
    assert_eq(patra_result_get_int(rs, 0, 1), 20, "age=20");
    patra_result_free(rs);

    patra_close(db);
}

fn test_alter_drop_last_col_rejected() {
    test_group("alter drop last col rejected");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE sole (id INT)");
    assert_eq(patra_exec(db, "ALTER TABLE sole DROP COLUMN id"),
              PATRA_ERR_COLCOUNT, "can't go to 0 cols");

    # 2-col table: drop one is fine, can't drop the other
    patra_exec(db, "CREATE TABLE two (id INT, name STR)");
    assert_eq(patra_exec(db, "ALTER TABLE two DROP COLUMN name"), PATRA_OK, "2→1 ok");
    assert_eq(patra_exec(db, "ALTER TABLE two DROP COLUMN id"),
              PATRA_ERR_COLCOUNT, "1→0 rejected");
    patra_close(db);
}

