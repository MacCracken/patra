    var rs = patra_query(db, "SELECT name FROM people");
    assert(rs != 0, "query ok");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_eq(patra_result_cols(rs), 1, "1 col");
    assert_streq(patra_result_col_name(rs, 0), "name", "col name");
    assert_streq(patra_result_get_str(rs, 0, 0), "alice", "row0");
    assert_streq(patra_result_get_str(rs, 4, 0), "eve", "row4");
