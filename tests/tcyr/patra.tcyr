# ── v0.10: Aggregates ─────────────────────────────────────────

fn test_aggregates() {
    test_group("aggregates");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    var rs = patra_query(db, "SELECT COUNT(*) FROM people");
    assert_eq(patra_result_count(rs), 1, "count 1 row");
    assert_eq(patra_result_get_int(rs, 0, 0), 5, "count=5");
    assert_streq(patra_result_col_name(rs, 0), "count", "col name");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT SUM(age) FROM people");
    assert_eq(patra_result_get_int(rs, 0, 0), 155, "sum=155");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT MIN(age) FROM people");
    assert_eq(patra_result_get_int(rs, 0, 0), 25, "min=25");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT MAX(age) FROM people");
    assert_eq(patra_result_get_int(rs, 0, 0), 40, "max=40");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT MIN(id) FROM people");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "min id=1");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT MAX(id) FROM people");
    assert_eq(patra_result_get_int(rs, 0, 0), 5, "max id=5");
    patra_result_free(rs);

    patra_close(db);
}

