}

# ── v0.10: CREATE INDEX ──────────────────────────────────────

fn test_create_index() {
    test_group("create index");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE ci (x INT, y INT, name STR)");
    patra_exec(db, "INSERT INTO ci VALUES (1, 10, 'a')");
    patra_exec(db, "INSERT INTO ci VALUES (2, 20, 'b')");
    patra_exec(db, "INSERT INTO ci VALUES (3, 30, 'c')");
    patra_exec(db, "INSERT INTO ci VALUES (4, 20, 'd')");

    # Create index on y column (not the first column)
    var r = patra_exec(db, "CREATE INDEX ON ci (y)");
    assert_eq(r, PATRA_OK, "create index ok");

    # Now WHERE y = 20 should use the index
    var rs = patra_query(db, "SELECT * FROM ci WHERE y = 20");
    assert_eq(patra_result_count(rs), 2, "y=20: 2 rows");
    patra_result_free(rs);

    # Range query on indexed column
    rs = patra_query(db, "SELECT * FROM ci WHERE y > 15");
    assert_eq(patra_result_count(rs), 3, "y>15: 3 rows");
    patra_result_free(rs);

    # 1.7.1: STR index now accepted (hash-keyed, verify on lookup).
    # Replaces the prior "str index rejected" assertion.
    r = patra_exec(db, "CREATE INDEX ON ci (name)");
    assert_eq(r, PATRA_OK, "str index accepted");

    # Missing table
    r = patra_exec(db, "CREATE INDEX ON ghost (x)");
    assert_eq(r, PATRA_ERR_NOTFOUND, "missing table");

    patra_close(db);
}

# ── v0.8.1: Indexed range scan ───────────────────────────────

fn test_indexed_range() {
    test_group("indexed range");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # id > 3 should use B-tree range [4, max]
    var rs = patra_query(db, "SELECT * FROM people WHERE id > 3");
    assert_eq(patra_result_count(rs), 2, "id>3: 2 rows");
    patra_result_free(rs);

    # id >= 3
    rs = patra_query(db, "SELECT * FROM people WHERE id >= 3");
    assert_eq(patra_result_count(rs), 3, "id>=3: 3 rows");
    patra_result_free(rs);

    # id < 3
    rs = patra_query(db, "SELECT * FROM people WHERE id < 3");
    assert_eq(patra_result_count(rs), 2, "id<3: 2 rows");
    patra_result_free(rs);

    # id <= 2
    rs = patra_query(db, "SELECT * FROM people WHERE id <= 2");
    assert_eq(patra_result_count(rs), 2, "id<=2: 2 rows");
    patra_result_free(rs);

    # id > 1 AND id < 5 (range [2,4])
    rs = patra_query(db, "SELECT * FROM people WHERE id > 1 AND id < 5");
    assert_eq(patra_result_count(rs), 3, "1<id<5: 3 rows");
    patra_result_free(rs);

    # id >= 2 AND id <= 4
    rs = patra_query(db, "SELECT * FROM people WHERE id >= 2 AND id <= 4");
    assert_eq(patra_result_count(rs), 3, "2<=id<=4: 3 rows");
    patra_result_free(rs);

    # Range with no results
    rs = patra_query(db, "SELECT * FROM people WHERE id > 100");
    assert_eq(patra_result_count(rs), 0, "id>100: 0 rows");
    patra_result_free(rs);

    patra_close(db);
}

fn test_indexed_range_with_filter() {
    test_group("indexed range + filter");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Index narrows by id, AND filter checks age
    var rs = patra_query(db, "SELECT * FROM people WHERE id >= 2 AND age = 25");
    assert_eq(patra_result_count(rs), 2, "id>=2 and age=25");
    patra_result_free(rs);

    # Index + ORDER BY + LIMIT
    rs = patra_query(db, "SELECT * FROM people WHERE id > 1 ORDER BY id LIMIT 2");
    assert_eq(patra_result_count(rs), 2, "range+order+limit");
    assert_eq(patra_result_get_int(rs, 0, 0), 2, "first id=2");
    assert_eq(patra_result_get_int(rs, 1, 0), 3, "second id=3");
    patra_result_free(rs);

    patra_close(db);
}


