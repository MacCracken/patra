fn test_alter_rename_table() {
    test_group("alter rename table");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE orig (id INT, name STR)");
    patra_exec(db, "INSERT INTO orig VALUES (1, 'a')");
    patra_exec(db, "INSERT INTO orig VALUES (2, 'b')");

    assert_eq(patra_exec(db, "ALTER TABLE orig RENAME TO renamed"), PATRA_OK, "rename ok");

    # Old name gone
    assert_eq(patra_exec(db, "INSERT INTO orig VALUES (3, 'c')"), PATRA_ERR_NOTFOUND, "old name gone");

    # New name works
    var rs = patra_query(db, "SELECT * FROM renamed");
    assert_eq(patra_result_count(rs), 2, "data preserved");
    patra_result_free(rs);

    # Collision rejected
    patra_exec(db, "CREATE TABLE other (id INT)");
    assert_eq(patra_exec(db, "ALTER TABLE renamed RENAME TO other"),
              PATRA_ERR_EXISTS, "collision rejected");

    # Unknown source
    assert_eq(patra_exec(db, "ALTER TABLE ghost RENAME TO x"),
              PATRA_ERR_NOTFOUND, "unknown source");

    patra_close(db);
}

fn test_alter_rename_column() {
    test_group("alter rename column");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE r (id INT, name STR, age INT)");
    patra_exec(db, "INSERT INTO r VALUES (1, 'alice', 30)");
    patra_exec(db, "INSERT INTO r VALUES (2, 'bob', 25)");
    patra_exec(db, "INSERT INTO r VALUES (3, 'carol', 35)");

    # Rename name → label
    assert_eq(patra_exec(db, "ALTER TABLE r RENAME COLUMN name TO label"),
              PATRA_OK, "rename ok");

    # WHERE on new name works
    var rs = patra_query(db, "SELECT * FROM r WHERE label = 'bob'");
    assert_eq(patra_result_count(rs), 1, "new name usable in WHERE");
    patra_result_free(rs);

    # WHERE on old name no longer resolves — returns no matches
    rs = patra_query(db, "SELECT * FROM r WHERE name = 'bob'");
    assert_eq(patra_result_count(rs), 0, "old name no longer resolves");
    patra_result_free(rs);

    # Column-list projection picks up the new name
    rs = patra_query(db, "SELECT label FROM r");
    assert_eq(patra_result_count(rs), 3, "project new name");
    assert_streq(patra_result_col_name(rs, 0), "label", "col name updated");
    patra_result_free(rs);

    # B-tree on id (first INT col) still works after rename of another col
    rs = patra_query(db, "SELECT * FROM r WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "index on id unaffected");
    patra_result_free(rs);

    # Rename to existing col name rejected
    assert_eq(patra_exec(db, "ALTER TABLE r RENAME COLUMN label TO age"),
              PATRA_ERR_EXISTS, "collision rejected");

    # Rename unknown col rejected
    assert_eq(patra_exec(db, "ALTER TABLE r RENAME COLUMN ghost TO x"),
              PATRA_ERR_NOTFOUND, "unknown col rejected");

    patra_close(db);
}

