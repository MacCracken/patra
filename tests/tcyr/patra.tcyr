# ── v1.3: VACUUM / B-tree compaction ─────────────────────────

fn _count_leaf_entries(fd, pg, inc_tombs) {
    var buf = fl_alloc(PAGE_SIZE);
    page_read(fd, pg, buf);
    var leaf = load64(buf + BT_LEAF);
    var nk = load64(buf + BT_NKEYS);
    var total = 0;
    if (leaf != 0) {
        if (inc_tombs != 0) { total = nk; }
        else {
            for (var i = 0; i < nk; i = i + 1) {
                if (load64(buf + BT_VALS + i * 8) != (0 - 1)) { total = total + 1; }
            }
        }
    } else {
        for (var i = 0; i <= nk; i = i + 1) {
            total = total + _count_leaf_entries(fd, load64(buf + BT_VALS + i * 8), inc_tombs);
        }
    }
    fl_free(buf);
    return total;
}

fn _tbl_idx_root(db, tname, tnlen) {
    var hdr = _db_hdr(db);
    var idx = tbl_find(hdr, tname, tnlen);
    var entry = _tbl_entry(hdr, idx);
    var spg = load64(entry + TBL_SCHEMA);
    var schema = fl_alloc(PAGE_SIZE);
    page_read(_db_fd(db), spg, schema);
    var ir = load64(schema + SCH_IDX_ROOT);
    fl_free(schema);
    return ir;
}

fn test_parse_vacuum() {
    test_group("parse vacuum");
    sql_tokenize("VACUUM people");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_VACUUM, "stmt vacuum");

    sql_tokenize("VACUUM");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "requires table name");
}

fn test_vacuum_reclaims() {
    test_group("vacuum reclaims");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE vac (id INT, name STR)");
    var _vsql[96];
    for (var i = 0; i < 100; i = i + 1) {
        var _vargs = vec_new();
        vec_push(_vargs, i + 1);
        fmt_sprintf(&_vsql, 96, "INSERT INTO vac VALUES (%d, 'x')", _vargs);
        patra_exec(db, &_vsql);
    }

    var ir = _tbl_idx_root(db, "vac", 3);
    var live_before = _count_leaf_entries(_db_fd(db), ir, 0);
    var all_before = _count_leaf_entries(_db_fd(db), ir, 1);
    assert_eq(live_before, 100, "100 live pre-delete");
    assert_eq(all_before, 100, "100 total pre-delete");

    # Delete 30 rows (ids 10-39). These get lazy-deleted in the B-tree.
    patra_exec(db, "DELETE FROM vac WHERE id >= 10 AND id < 40");

    var live_after_del = _count_leaf_entries(_db_fd(db), ir, 0);
    var all_after_del = _count_leaf_entries(_db_fd(db), ir, 1);
    assert_eq(live_after_del, 70, "70 live post-delete");
    assert_eq(all_after_del, 100, "100 total incl tombstones");

    # VACUUM reclaims the tombstones
    assert_eq(patra_exec(db, "VACUUM vac"), PATRA_OK, "vacuum ok");

    var all_post_vac = _count_leaf_entries(_db_fd(db), ir, 1);
    assert_eq(all_post_vac, 70, "tombstones reclaimed");

    # Queries still correct
    var rs = patra_query(db, "SELECT * FROM vac WHERE id = 50");
    assert_eq(patra_result_count(rs), 1, "surviving row findable");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT * FROM vac WHERE id = 20");
    assert_eq(patra_result_count(rs), 0, "deleted row not findable");
    patra_result_free(rs);

    rs = patra_query(db, "SELECT COUNT(*) FROM vac");
    assert_eq(patra_result_get_int(rs, 0, 0), 70, "count=70");
    patra_result_free(rs);

    patra_close(db);
}

fn test_vacuum_no_index() {
    test_group("vacuum no index");
    cleanup();
