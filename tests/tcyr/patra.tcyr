    patra_exec(db, "CREATE TABLE big (id INT, x INT)");
    for (var i = 1; i <= 200; i = i + 1) {
        patra_exec(db, "INSERT INTO big VALUES (1, 0)");
    }
    # All 200 have id=1
    var rs = patra_query(db, "SELECT * FROM big WHERE id = 1");
