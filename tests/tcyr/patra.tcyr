    sql_tokenize("DROP");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "drop alone");

    # DROP TABLE without name
    sql_tokenize("DROP TABLE");
    assert_eq(sql_parse(), PATRA_ERR_SYNTAX, "drop table no name");
}

# ── v0.16: WAL overflow ────────────────────────────────────

fn test_wal_overflow() {
    test_group("wal overflow");
    cleanup();
    var db = patra_open(_tpath);

    # Create a table with many columns to make rows large
    patra_exec(db, "CREATE TABLE wo (id INT, a STR, b STR, c STR)");

    # Start explicit transaction
    patra_begin(db);

    # Insert many rows to force many page writes
    # Each STR is 256 bytes, row = 8 + 256*3 = 776 bytes
    # Page fits ~5 rows (776*5 = 3880 < 4072 available)
    # 64 pages * 5 rows = 320 rows to fill WAL
    # We need > 64 unique page writes to trigger overflow
    var i = 0;
    while (i < 400) {
        patra_exec(db, "INSERT INTO wo VALUES (1, 'x', 'y', 'z')");
        i = i + 1;
    }

    # Commit returns PATRA_ERR_FULL to signal WAL overflow
    var r = patra_commit(db);
    assert_eq(r, PATRA_ERR_FULL, "commit reports overflow");

    # Data was still committed (just not crash-safe beyond 64 pages)
    var rs = patra_query(db, "SELECT COUNT(*) FROM wo");
    assert(patra_result_get_int(rs, 0, 0) > 0, "data committed");
    patra_result_free(rs);

    patra_close(db);
}

# ── v0.17: Hardening ────────────────────────────────────────

fn test_update_indexed_col() {
    test_group("update indexed col");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # id is the auto-indexed column. Change alice's id from 1 to 100.
    var r = patra_exec(db, "UPDATE people SET id = 100 WHERE name = 'alice'");
    assert_eq(r, PATRA_OK, "update id ok");

    # Old id should not find alice
    var rs = patra_query(db, "SELECT * FROM people WHERE id = 1");
    assert_eq(patra_result_count(rs), 0, "old id=1 gone");
    patra_result_free(rs);

    # New id should find alice via index
    rs = patra_query(db, "SELECT * FROM people WHERE id = 100");
    assert_eq(patra_result_count(rs), 1, "new id=100");
    assert_streq(patra_result_get_str(rs, 0, 1), "alice", "still alice");
    patra_result_free(rs);

    # Other rows unaffected
    rs = patra_query(db, "SELECT * FROM people WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "bob intact");
    patra_result_free(rs);

    # Range query still works
    rs = patra_query(db, "SELECT * FROM people WHERE id >= 3 AND id <= 5");
    assert_eq(patra_result_count(rs), 3, "range 3-5 intact");
    patra_result_free(rs);

    patra_close(db);
}

fn test_drop_recreate() {
    test_group("drop recreate");
    cleanup();
    var db = patra_open(_tpath);

    # Create, populate, drop
    patra_exec(db, "CREATE TABLE reuse (id INT, val STR)");
    patra_exec(db, "INSERT INTO reuse VALUES (1, 'old')");
    patra_exec(db, "DROP TABLE reuse");

    # Recreate with same name, different schema
    var r = patra_exec(db, "CREATE TABLE reuse (x INT, y INT)");
    assert_eq(r, PATRA_OK, "recreate ok");

    # Insert into new schema
    r = patra_exec(db, "INSERT INTO reuse VALUES (10, 20)");
    assert_eq(r, PATRA_OK, "insert new schema");

    var rs = patra_query(db, "SELECT * FROM reuse");
    assert_eq(patra_result_count(rs), 1, "1 row");
    assert_eq(patra_result_get_int(rs, 0, 0), 10, "x=10");
    assert_eq(patra_result_get_int(rs, 0, 1), 20, "y=20");
    patra_result_free(rs);

    # Old data is gone — only 1 row, not 2
    rs = patra_query(db, "SELECT COUNT(*) FROM reuse");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "count=1");
    patra_result_free(rs);

    patra_close(db);
}

fn test_tx_rollback_persistence() {
    test_group("tx rollback persist");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE txp (id INT, val STR)");
    patra_exec(db, "INSERT INTO txp VALUES (1, 'keep')");

    # Begin tx, insert more, rollback
    patra_begin(db);
    patra_exec(db, "INSERT INTO txp VALUES (2, 'discard')");
    patra_exec(db, "INSERT INTO txp VALUES (3, 'discard')");
    patra_rollback(db);

    # Close and reopen
    patra_close(db);
    db = patra_open(_tpath);

    # Only the pre-tx row should survive
    var rs = patra_query(db, "SELECT * FROM txp");
    assert_eq(patra_result_count(rs), 1, "1 row after reopen");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "id=1 kept");
    assert_streq(patra_result_get_str(rs, 0, 1), "keep", "val=keep");
    patra_result_free(rs);

    patra_close(db);
}

fn test_multipage_indexed() {
    test_group("multipage indexed");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE mp (id INT, name STR)");

    # Row = 8 + 256 = 264 bytes. Page capacity = (4096-24)/264 = 15 rows.
    # Insert 50 rows to span 4 pages.
    var i = 1;
    while (i <= 50) {
        patra_exec(db, "INSERT INTO mp VALUES (1, 'row')");
        i = i + 1;
    }

    # Full scan
    var rs = patra_query(db, "SELECT COUNT(*) FROM mp");
    assert_eq(patra_result_get_int(rs, 0, 0), 50, "count=50");
    patra_result_free(rs);

    # Index query (all have id=1)
    rs = patra_query(db, "SELECT * FROM mp WHERE id = 1");
    assert_eq(patra_result_count(rs), 50, "indexed all 50");
    patra_result_free(rs);

    # Range that matches nothing
    rs = patra_query(db, "SELECT * FROM mp WHERE id > 1");
    assert_eq(patra_result_count(rs), 0, "id>1 = 0");
    patra_result_free(rs);

    patra_close(db);
}

# ── v1.6: BLOB column ───────────────────────────────────────

# Fill `buf` with a deterministic byte pattern of length `len`. Pattern is
# `(i + seed) & 0xFF` so the full range of byte values is exercised.
fn _bytes_fill(buf, len, seed) {
    for (var i = 0; i < len; i = i + 1) {
        store8(buf + i, (i + seed) & 255);
    }
    return 0;
}

# Compare two buffers byte-for-byte, return 1 if equal.
fn _bytes_eq(a, b, len) {
    for (var i = 0; i < len; i = i + 1) {
        if (load8(a + i) != load8(b + i)) { return 0; }
    }
    return 1;
}

# Helper: insert a single (hash STR, content BLOB) row into `objects`.
fn _obj_insert(db, hash, content, clen) {
    var types = fl_alloc(2 * 8);
    var ivals = fl_alloc(2 * 8);
    var sptrs = fl_alloc(2 * 8);
    var slens = fl_alloc(2 * 8);
    var bptrs = fl_alloc(2 * 8);
    var blens = fl_alloc(2 * 8);
    memset(ivals, 0, 16);
    memset(sptrs, 0, 16);
    memset(slens, 0, 16);
    memset(bptrs, 0, 16);
    memset(blens, 0, 16);
    store64(types + 0 * 8, COL_STR);
    store64(sptrs + 0 * 8, hash);
    store64(slens + 0 * 8, strlen(hash));
    store64(types + 1 * 8, COL_BYTES);
    store64(bptrs + 1 * 8, content);
    store64(blens + 1 * 8, clen);
    var r = patra_insert_row(db, "objects", 7, 2, types, ivals, sptrs, slens, bptrs, blens);
    fl_free(types); fl_free(ivals); fl_free(sptrs);
    fl_free(slens); fl_free(bptrs); fl_free(blens);
    return r;
}

fn test_bytes_parse() {
    test_group("bytes parse");
    sql_tokenize("CREATE TABLE objects (hash STR, content BLOB)");
    assert_eq(sql_parse(), PATRA_OK, "parse ok");
    assert_eq(load64(_sql_pr + PR_STMT), STMT_CREATE, "create stmt");
    assert_eq(load64(_sql_pr + PR_COUNT), 2, "2 cols");
    var c1 = _sql_pr + PR_ITEMS + 1 * CR_SZ;
    assert_eq(load64(c1 + CR_TYPE), COL_BYTES, "col1 BLOB");
}

fn test_bytes_create_table() {
    test_group("bytes create table");
    cleanup();
    var db = patra_open(_tpath);
    assert_eq(patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)"),
              PATRA_OK, "create");

    # SQL INSERT on a BLOB column must reject — there's no way to carry
    # binary payloads through the tokenizer.
    assert_eq(patra_exec(db, "INSERT INTO objects VALUES ('abc', 'def')"),
              PATRA_ERR_TYPE, "sql insert rejected");
    patra_close(db);
}

fn test_bytes_insert_read_small() {
    test_group("bytes insert read small");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");

    var payload = fl_alloc(128);
    _bytes_fill(payload, 100, 42);
    assert_eq(_obj_insert(db, "hash_small", payload, 100), PATRA_OK, "insert ok");

    var rs = patra_query(db, "SELECT * FROM objects");
    assert_eq(patra_result_count(rs), 1, "1 row");
    assert_eq(patra_result_get_bytes_len(rs, 0, 1), 100, "blob len");
    var out = fl_alloc(128);
    memset(out, 0, 128);
    assert_eq(patra_result_read_bytes(db, rs, 0, 1, out), PATRA_OK, "read ok");
    assert_eq(_bytes_eq(payload, out, 100), 1, "bytes equal");
    fl_free(out);
    fl_free(payload);
    patra_result_free(rs);
    patra_close(db);
}

fn test_bytes_empty() {
    test_group("bytes empty");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    # Empty blob: ptr NULL, len 0 → no chain pages allocated.
    assert_eq(_obj_insert(db, "hash_empty", 0, 0), PATRA_OK, "insert empty");
    var rs = patra_query(db, "SELECT * FROM objects");
    assert_eq(patra_result_get_bytes_len(rs, 0, 1), 0, "len 0");
    # Read with zero-length buffer still returns PATRA_OK.
    var out = fl_alloc(16);
    assert_eq(patra_result_read_bytes(db, rs, 0, 1, out), PATRA_OK, "read empty");
    fl_free(out);
    patra_result_free(rs);
    patra_close(db);
}

fn test_bytes_multipage() {
    test_group("bytes multipage");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");

    # 10_000 bytes → ceil(10000/4072) = 3 chain pages
    var sz = 10000;
    var payload = fl_alloc(sz);
    _bytes_fill(payload, sz, 7);
    assert_eq(_obj_insert(db, "hash_big", payload, sz), PATRA_OK, "insert big");

    var rs = patra_query(db, "SELECT * FROM objects");
    assert_eq(patra_result_get_bytes_len(rs, 0, 1), sz, "len 10000");
    var out = fl_alloc(sz);
    memset(out, 0, sz);
    assert_eq(patra_result_read_bytes(db, rs, 0, 1, out), PATRA_OK, "read big");
    assert_eq(_bytes_eq(payload, out, sz), 1, "10k bytes equal");
    fl_free(out);
    fl_free(payload);
    patra_result_free(rs);
    patra_close(db);
}

fn test_bytes_many_rows() {
    test_group("bytes many rows");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");

    # Twenty rows with distinct payloads
    var payload = fl_alloc(256);
    for (var i = 0; i < 20; i = i + 1) {
        _bytes_fill(payload, 200 + i, i);
        var hash = fl_alloc(16);
        memcpy(hash, "h", 1);
        store8(hash + 1, 48 + (i / 10));  # tens digit
        store8(hash + 2, 48 + (i % 10));  # ones digit
        store8(hash + 3, 0);
        _obj_insert(db, hash, payload, 200 + i);
        fl_free(hash);
    }
    fl_free(payload);

    var rs = patra_query(db, "SELECT * FROM objects");
    assert_eq(patra_result_count(rs), 20, "20 rows");
    # Verify a handful of rows round-trip correctly
    for (var j = 0; j < 20; j = j + 3) {
        var expected = fl_alloc(256);
        _bytes_fill(expected, 200 + j, j);
        var got = fl_alloc(256);
        memset(got, 0, 256);
        assert_eq(patra_result_get_bytes_len(rs, j, 1), 200 + j, "len");
        assert_eq(patra_result_read_bytes(db, rs, j, 1, got), PATRA_OK, "read");
        assert_eq(_bytes_eq(expected, got, 200 + j), 1, "equal");
        fl_free(expected); fl_free(got);
    }
    patra_result_free(rs);
    patra_close(db);
}

fn test_bytes_delete_frees_chain() {
    test_group("bytes delete frees chain");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    var payload = fl_alloc(9000);
    _bytes_fill(payload, 9000, 1);
    _obj_insert(db, "big1", payload, 9000);
    _obj_insert(db, "big2", payload, 9000);

    var hdr = _db_hdr(db);
    var pg_before = load64(hdr + HDR_PGCOUNT);

    # DELETE with a WHERE on hash narrows to one row
    assert_eq(patra_exec(db, "DELETE FROM objects WHERE hash = 'big1'"),
              PATRA_OK, "delete ok");

    var pg_after = load64(hdr + HDR_PGCOUNT);
    # Page count doesn't shrink — freed pages go onto the free list.
    assert_eq(pg_after, pg_before, "pgcount unchanged");
    # Free-list head must be non-zero if pages were reclaimed
    assert_eq(load64(hdr + HDR_FREEHEAD) != 0, 1, "freehead set");

    var rs = patra_query(db, "SELECT * FROM objects");
    assert_eq(patra_result_count(rs), 1, "1 row remaining");
    patra_result_free(rs);
    fl_free(payload);
    patra_close(db);
}

fn test_bytes_drop_table_frees() {
    test_group("bytes drop frees chains");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    var payload = fl_alloc(9000);
    _bytes_fill(payload, 9000, 2);
    _obj_insert(db, "d1", payload, 9000);
    _obj_insert(db, "d2", payload, 9000);
    _obj_insert(db, "d3", payload, 9000);

    var hdr = _db_hdr(db);
    var pg_before = load64(hdr + HDR_PGCOUNT);

    assert_eq(patra_exec(db, "DROP TABLE objects"), PATRA_OK, "drop");
    # Chain pages must be reclaimed. Recreate and check reuse by alloc.
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    _obj_insert(db, "d4", payload, 9000);
    var pg_after = load64(hdr + HDR_PGCOUNT);
    # If chains were not freed, we'd have allocated 3 more blob pages here.
    # With free-list reclamation, pg_after should not exceed pg_before + a
    # small fudge (schema page + data page for the new table).
    assert_eq(pg_after <= pg_before + 4, 1, "chain pages reclaimed");

    fl_free(payload);
    patra_close(db);
}

fn test_bytes_where_no_match() {
    test_group("bytes where no match");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    var payload = fl_alloc(64);
    _bytes_fill(payload, 50, 3);
    _obj_insert(db, "h1", payload, 50);
    fl_free(payload);

    # WHERE on the BLOB column should never match (by design)
    var rs = patra_query(db, "SELECT * FROM objects WHERE content = 'whatever'");
    assert_eq(patra_result_count(rs), 0, "blob WHERE no match");
    patra_result_free(rs);

    # WHERE on the STR column still works as normal
    rs = patra_query(db, "SELECT * FROM objects WHERE hash = 'h1'");
    assert_eq(patra_result_count(rs), 1, "str WHERE still works");
    patra_result_free(rs);
    patra_close(db);
}

fn test_bytes_update_rejected() {
    test_group("bytes update rejected");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    var payload = fl_alloc(64);
    _bytes_fill(payload, 50, 4);
    _obj_insert(db, "h_upd", payload, 50);
    fl_free(payload);

    # Cannot UPDATE a BLOB column via SQL
    assert_eq(patra_exec(db, "UPDATE objects SET content = 'nope' WHERE hash = 'h_upd'"),
              PATRA_ERR_TYPE, "update blob rejected");
    # Non-BLOB columns still updatable
    assert_eq(patra_exec(db, "UPDATE objects SET hash = 'h_renamed' WHERE hash = 'h_upd'"),
              PATRA_OK, "hash update ok");
    patra_close(db);
}

fn test_bytes_alter_add() {
    test_group("bytes alter add");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (id INT, name STR)");
    patra_exec(db, "INSERT INTO t VALUES (1, 'alice')");
    patra_exec(db, "INSERT INTO t VALUES (2, 'bob')");

    assert_eq(patra_exec(db, "ALTER TABLE t ADD COLUMN data BLOB"),
              PATRA_OK, "add blob col");

    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 2, "2 rows");
    # New column is empty (0,0)
