    patra_close(db2);
}

fn test_result_str_len() {
    test_group("result str_len");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (id INT, name STR)");
    patra_exec(db, "INSERT INTO t VALUES (1, '')");
    patra_exec(db, "INSERT INTO t VALUES (2, 'alice')");

    # 255 'a' bytes — the COL_STR_SZ-1 ceiling row_write_str clamps to.
    var max = fl_alloc(256);
    memset(max, 0, 256);
    for (var i = 0; i < 255; i = i + 1) { store8(max + i, 97); }
    var types = fl_alloc(16);
    var ivals = fl_alloc(16);
    var sptrs = fl_alloc(16);
    var slens = fl_alloc(16);
    memset(types, 0, 16); memset(ivals, 0, 16);
    memset(sptrs, 0, 16); memset(slens, 0, 16);
    store64(types + 0, COL_INT);
    store64(ivals + 0, 3);
    store64(types + 8, COL_STR);
    store64(sptrs + 8, max);
    store64(slens + 8, 255);
    assert_eq(patra_insert_row(db, "t", 1, 2, types, ivals, sptrs, slens, 0, 0), PATRA_OK, "insert max");
    fl_free(slens); fl_free(sptrs); fl_free(ivals); fl_free(types); fl_free(max);

    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 3, "3 rows");
    assert_eq(patra_result_get_str_len(rs, 0, 1), 0, "empty");
    assert_eq(patra_result_get_str_len(rs, 1, 1), 5, "alice");
    assert_eq(patra_result_get_str_len(rs, 2, 1), 255, "max 255");
    assert_eq(patra_result_get_str_len(rs, 0, 0), 0 - 1, "non-STR returns -1");
    patra_result_free(rs);
    patra_close(db);
}

