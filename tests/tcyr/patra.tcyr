fn test_select_col_multi() {
    test_group("select col multi");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Project (name, age) — drop id, reorder
    var rs = patra_query(db, "SELECT name, age FROM people");
    assert_eq(patra_result_cols(rs), 2, "2 cols");
    assert_streq(patra_result_col_name(rs, 0), "name", "col0=name");
    assert_streq(patra_result_col_name(rs, 1), "age", "col1=age");
    assert_streq(patra_result_get_str(rs, 0, 0), "alice", "alice name");
    assert_eq(patra_result_get_int(rs, 0, 1), 30, "alice age");
    assert_streq(patra_result_get_str(rs, 1, 0), "bob", "bob name");
    assert_eq(patra_result_get_int(rs, 1, 1), 25, "bob age");
    patra_result_free(rs);

    # Reorder: age, id, name
    rs = patra_query(db, "SELECT age, id, name FROM people");
    assert_eq(patra_result_cols(rs), 3, "3 cols reordered");
    assert_eq(patra_result_get_int(rs, 0, 0), 30, "r0 age");
    assert_eq(patra_result_get_int(rs, 0, 1), 1, "r0 id");
    assert_streq(patra_result_get_str(rs, 0, 2), "alice", "r0 name");
    patra_result_free(rs);

    patra_close(db);
}

fn test_select_col_where_order_limit() {
    test_group("select col where order limit");
    cleanup();
    var db = patra_open(_tpath);
    _setup_people(db);

    # Projection with WHERE referencing non-projected col
    var rs = patra_query(db, "SELECT name FROM people WHERE age > 28");
    assert_eq(patra_result_count(rs), 3, "age>28: 3 rows");
    assert_eq(patra_result_cols(rs), 1, "1 col");
    patra_result_free(rs);

    # ORDER BY on non-projected col (sort runs before projection)
    rs = patra_query(db, "SELECT name FROM people ORDER BY age");
    assert_eq(patra_result_count(rs), 5, "5 rows");
    assert_streq(patra_result_get_str(rs, 4, 0), "eve", "last = eve (age 40)");
    patra_result_free(rs);

    # Projection + LIMIT
    rs = patra_query(db, "SELECT id, name FROM people LIMIT 2");
    assert_eq(patra_result_count(rs), 2, "limit 2");
    assert_eq(patra_result_cols(rs), 2, "2 cols");
    patra_result_free(rs);

    patra_close(db);
}

