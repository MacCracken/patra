    assert_eq(patra_result_get_bytes_len(rs, 1, 2), 0, "row1 empty");
    patra_result_free(rs);
    patra_close(db);
}

fn test_bytes_alter_drop_frees() {
    test_group("bytes alter drop frees");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (id INT, content BLOB)");

    var types = fl_alloc(16);
    var ivals = fl_alloc(16);
    var sptrs = fl_alloc(16);
    var slens = fl_alloc(16);
    var bptrs = fl_alloc(16);
    var blens = fl_alloc(16);
    memset(ivals, 0, 16); memset(sptrs, 0, 16); memset(slens, 0, 16);
    memset(bptrs, 0, 16); memset(blens, 0, 16);
    store64(types + 0, COL_INT);
    store64(types + 8, COL_BYTES);

    var payload = fl_alloc(9000);
    _bytes_fill(payload, 9000, 5);
    store64(bptrs + 8, payload);
    store64(blens + 8, 9000);
    for (var i = 1; i <= 3; i = i + 1) {
        store64(ivals + 0, i);
        patra_insert_row(db, "objects", 7, 2, types, ivals, sptrs, slens, bptrs, blens);
    }
    fl_free(types); fl_free(ivals); fl_free(sptrs);
    fl_free(slens); fl_free(bptrs); fl_free(blens);

    var hdr = _db_hdr(db);
    var fh_before = load64(hdr + HDR_FREEHEAD);

    assert_eq(patra_exec(db, "ALTER TABLE objects DROP COLUMN content"),
              PATRA_OK, "drop blob col");

    # Free list must have grown (chain pages reclaimed by drop)
    var fh_after = load64(hdr + HDR_FREEHEAD);
    assert_eq(fh_after != fh_before, 1, "free list changed");

    var rs = patra_query(db, "SELECT * FROM objects");
    assert_eq(patra_result_count(rs), 3, "3 rows kept");
    assert_eq(patra_result_cols(rs), 1, "1 col left");
    patra_result_free(rs);
    fl_free(payload);
    patra_close(db);
}

fn test_bytes_persistence() {
    test_group("bytes persistence");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objects (hash STR, content BLOB)");
    var payload = fl_alloc(5000);
    _bytes_fill(payload, 5000, 9);
    _obj_insert(db, "persist", payload, 5000);
    patra_close(db);

    var db2 = patra_open(_tpath);
    var rs = patra_query(db2, "SELECT * FROM objects");
    assert_eq(patra_result_count(rs), 1, "reopen 1 row");
    assert_eq(patra_result_get_bytes_len(rs, 0, 1), 5000, "len 5000");
    var out = fl_alloc(5000);
    memset(out, 0, 5000);
    assert_eq(patra_result_read_bytes(db2, rs, 0, 1, out), PATRA_OK, "read");
    assert_eq(_bytes_eq(payload, out, 5000), 1, "bytes equal");
    fl_free(out);
    fl_free(payload);
    patra_result_free(rs);
    patra_close(db2);
}

fn test_prepare_insert_select() {
    test_group("prepared INSERT + SELECT");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (id INT, name STR)");

    var ins = patra_prepare(db, "INSERT INTO t VALUES (1, 'alice')");
    assert(ins != 0, "prepare insert ok");
    assert_eq(patra_exec_prepared(db, ins), PATRA_OK, "insert run 1");
    # Re-running the same prepared stmt — same row inserted again.
    assert_eq(patra_exec_prepared(db, ins), PATRA_OK, "insert run 2");
    patra_finalize(ins);

    var sel = patra_prepare(db, "SELECT * FROM t");
    assert(sel != 0, "prepare select ok");
    var rs = patra_query_prepared(db, sel);
    assert_eq(patra_result_count(rs), 2, "two rows via prepared select");
    patra_result_free(rs);
    patra_finalize(sel);
    patra_close(db);
}

fn test_prepare_all_stmt_types() {
    test_group("prepared dispatch covers DDL/DML");
    cleanup();
    var db = patra_open(_tpath);
    var pc = patra_prepare(db, "CREATE TABLE t (id INT, name STR)");
    assert_eq(patra_exec_prepared(db, pc), PATRA_OK, "prepared CREATE");
    patra_finalize(pc);

    var pi = patra_prepare(db, "INSERT INTO t VALUES (1, 'a')");
    patra_exec_prepared(db, pi);
    patra_exec_prepared(db, pi);
    patra_exec_prepared(db, pi);
    patra_finalize(pi);

    var pu = patra_prepare(db, "UPDATE t SET name = 'b' WHERE id = 1");
    assert_eq(patra_exec_prepared(db, pu), PATRA_OK, "prepared UPDATE");
    patra_finalize(pu);

    var pd = patra_prepare(db, "DELETE FROM t WHERE id = 1");
    assert_eq(patra_exec_prepared(db, pd), PATRA_OK, "prepared DELETE");
    patra_finalize(pd);

    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 0, "all rows deleted");
    patra_result_free(rs);
    patra_close(db);
}

fn test_prepare_syntax_error() {
    test_group("prepared syntax error returns 0");
    cleanup();
    var db = patra_open(_tpath);
    var bad = patra_prepare(db, "BANANA");
    assert_eq(bad, 0, "bad SQL → 0 stmt");
    patra_close(db);
}

fn test_prepare_owns_sql_buffer() {
    test_group("prepared stmt owns its SQL");
    # The stmt copies its SQL on prepare; freeing/overwriting the input
    # buffer afterwards must not affect later exec_prepared calls.
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (id INT, name STR)");

    var sql = fl_alloc(64);
    var src = "INSERT INTO t VALUES (7, 'x')";
    var n = strlen(src);
    memcpy(sql, src, n);
    store8(sql + n, 0);
    var p = patra_prepare(db, sql);
    # Trash the input — must not break the prepared stmt.
    memset(sql, 0, 64);
    fl_free(sql);

    assert_eq(patra_exec_prepared(db, p), PATRA_OK, "exec after input freed");
    var rs = patra_query(db, "SELECT * FROM t WHERE id = 7");
    assert_eq(patra_result_count(rs), 1, "row inserted");
    patra_result_free(rs);
    patra_finalize(p);
    patra_close(db);
}

fn test_prepare_finalize_safe() {
    test_group("patra_finalize handles 0");
    assert_eq(patra_finalize(0), 0, "finalize(0) is no-op");
}

fn test_prepare_str_index() {
    test_group("prepared INSERT OR IGNORE on STR-indexed");
    # Exercises the slab + memeq256 + prepared path together — the three
    # 1.8.2 changes in one workload.
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE objs (hash STR, val INT)");
    patra_exec(db, "CREATE INDEX ON objs (hash)");
    patra_exec(db, "INSERT INTO objs VALUES ('first', 1)");

    var p = patra_prepare(db, "INSERT OR IGNORE INTO objs VALUES ('first', 99)");
    # Run 10 times — every run hits the conflict probe + memeq256 verify.
    for (var i = 0; i < 10; i = i + 1) {
        assert_eq(patra_exec_prepared(db, p), PATRA_OK, "ignored");
    }
    patra_finalize(p);
    var rs = patra_query(db, "SELECT * FROM objs");
    assert_eq(patra_result_count(rs), 1, "still 1 row");
    assert_eq(patra_result_get_int(rs, 0, 1), 1, "original val preserved");
    patra_result_free(rs);
    patra_close(db);
}

fn test_sync_mode_default_full() {
    test_group("sync mode default FULL");
    cleanup();
    var db = patra_open(_tpath);
    assert_eq(patra_get_sync_mode(db), PATRA_SYNC_FULL, "default FULL");
    patra_close(db);
}

fn test_sync_mode_batch_visibility() {
    test_group("BATCH mode same-process visibility");
    # In BATCH mode the writes aren't fsync'd per exec, but they're still
    # in OS page cache + addressable through this fd, so SELECTs see them.
    # Crash-durability isn't asserted here — that needs OS-level coordination
    # we can't run inside the test binary.
    cleanup();
    var db = patra_open(_tpath);
    patra_set_sync_mode(db, PATRA_SYNC_BATCH);
    patra_exec(db, "CREATE TABLE t (id INT, val STR)");
    for (var i = 0; i < 10; i = i + 1) {
        patra_exec(db, "INSERT INTO t VALUES (1, 'x')");
    }
    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 10, "all 10 visible same process");
    patra_result_free(rs);
    patra_close(db);
}

fn test_sync_mode_flush_explicit() {
    test_group("explicit patra_flush clears pending");
    cleanup();
    var db = patra_open(_tpath);
    patra_set_sync_mode(db, PATRA_SYNC_BATCH);
    patra_exec(db, "CREATE TABLE t (id INT)");
    patra_exec(db, "INSERT INTO t VALUES (1)");
    patra_exec(db, "INSERT INTO t VALUES (2)");
    # Flush forces the fdatasync; should be idempotent.
    assert_eq(patra_flush(db), PATRA_OK, "flush ok");
    assert_eq(patra_flush(db), PATRA_OK, "flush idempotent");
    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 2, "both rows after flush");
    patra_result_free(rs);
    patra_close(db);
}

fn test_sync_mode_close_flushes() {
    test_group("patra_close flushes pending");
    cleanup();
    var db = patra_open(_tpath);
    patra_set_sync_mode(db, PATRA_SYNC_BATCH);
    patra_exec(db, "CREATE TABLE t (id INT)");
    patra_exec(db, "INSERT INTO t VALUES (42)");
    # Close without explicit flush — must not lose data.
    patra_close(db);

    var db2 = patra_open(_tpath);
    var rs = patra_query(db2, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 1, "row survives close");
    assert_eq(patra_result_get_int(rs, 0, 0), 42, "right val");
    patra_result_free(rs);
    patra_close(db2);
}

fn test_sync_mode_reopen_default() {
    test_group("sync mode resets to FULL on reopen");
    # The mode is per-handle, not persisted in the file. Reopening gives
    # back FULL even if the previous handle was BATCH.
    cleanup();
    var db = patra_open(_tpath);
    patra_set_sync_mode(db, PATRA_SYNC_BATCH);
    patra_exec(db, "CREATE TABLE t (id INT)");
    patra_close(db);

    var db2 = patra_open(_tpath);
    assert_eq(patra_get_sync_mode(db2), PATRA_SYNC_FULL, "reopen → FULL");
    patra_close(db2);
}

fn test_sync_mode_switch_flushes() {
    test_group("set_sync_mode flushes on switch");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE t (id INT)");
    patra_set_sync_mode(db, PATRA_SYNC_BATCH);
    for (var i = 0; i < 5; i = i + 1) { patra_exec(db, "INSERT INTO t VALUES (1)"); }
    # Switching back to FULL flushes any pending writes.
    patra_set_sync_mode(db, PATRA_SYNC_FULL);
    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 5, "5 rows after mode switch");
    patra_result_free(rs);
    patra_close(db);
}

fn test_sync_mode_auto_flush_threshold() {
    test_group("BATCH auto-flush at threshold");
    # PATRA_BATCH_FLUSH_N is 64. After 70 inserts in BATCH mode the auto-
    # flush has fired at least once; the data is consistent and reads
    # correctly afterwards.
    cleanup();
    var db = patra_open(_tpath);
    patra_set_sync_mode(db, PATRA_SYNC_BATCH);
    patra_exec(db, "CREATE TABLE t (id INT)");
    for (var i = 0; i < 70; i = i + 1) { patra_exec(db, "INSERT INTO t VALUES (1)"); }
    var rs = patra_query(db, "SELECT * FROM t");
    assert_eq(patra_result_count(rs), 70, "70 rows after auto-flush");
    patra_result_free(rs);
    patra_close(db);
}

fn test_str_index_create() {
