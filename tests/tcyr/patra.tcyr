fn test_alter_add_column_populated() {
    test_group("alter add column populated");
    cleanup();
    var db = patra_open(_tpath);
    patra_exec(db, "CREATE TABLE p (id INT, name STR)");
    patra_exec(db, "INSERT INTO p VALUES (1, 'alice')");
    patra_exec(db, "INSERT INTO p VALUES (2, 'bob')");
    patra_exec(db, "INSERT INTO p VALUES (3, 'carol')");

    assert_eq(patra_exec(db, "ALTER TABLE p ADD COLUMN age INT"),
              PATRA_OK, "add col ok");

    # Existing rows keep their values; new col defaults to 0
    var rs = patra_query(db, "SELECT * FROM p");
    assert_eq(patra_result_count(rs), 3, "3 rows");
    assert_eq(patra_result_cols(rs), 3, "3 cols");
    assert_eq(patra_result_get_int(rs, 0, 0), 1, "r0 id");
    assert_streq(patra_result_get_str(rs, 0, 1), "alice", "r0 name");
    assert_eq(patra_result_get_int(rs, 0, 2), 0, "r0 age default");
    assert_eq(patra_result_get_int(rs, 2, 0), 3, "r2 id");
    assert_streq(patra_result_get_str(rs, 2, 1), "carol", "r2 name");
    patra_result_free(rs);

    # Index on id still works (rebuilt)
    rs = patra_query(db, "SELECT * FROM p WHERE id = 2");
    assert_eq(patra_result_count(rs), 1, "index rebuilt");
    assert_streq(patra_result_get_str(rs, 0, 1), "bob", "bob found");
    patra_result_free(rs);

    # Can now insert 3-col rows
    patra_exec(db, "INSERT INTO p VALUES (4, 'dave', 28)");
    rs = patra_query(db, "SELECT * FROM p WHERE id = 4");
    assert_eq(patra_result_get_int(rs, 0, 2), 28, "dave age=28");
    patra_result_free(rs);

    # UPDATE new col on old row works
    patra_exec(db, "UPDATE p SET age = 30 WHERE id = 1");
    rs = patra_query(db, "SELECT * FROM p WHERE id = 1");
    assert_eq(patra_result_get_int(rs, 0, 2), 30, "alice age updated");
    patra_result_free(rs);

    patra_close(db);
}

