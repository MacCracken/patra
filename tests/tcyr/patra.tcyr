    patra_exec(db, "CREATE TABLE strs (name STR, val STR)");
    patra_exec(db, "INSERT INTO strs VALUES ('a', 'one')");
    patra_exec(db, "INSERT INTO strs VALUES ('b', 'two')");

    # No index on STR-first table, should still work via scan
    var rs = patra_query(db, "SELECT * FROM strs WHERE name = 'a'");
    assert_eq(patra_result_count(rs), 1, "scan fallback");
    patra_result_free(rs);
    patra_close(db);
}

fn test_btree_many() {
    test_group("btree many inserts");
