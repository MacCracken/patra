# patra.bcyr — Patra benchmarks (v0.1 + v0.2)

include "src/lib.cyr"
include "lib/bench.cyr"
include "lib/fnptr.cyr"

var _bpath = "/tmp/patra_bench.patra";
var _bdb = 0;

fn _bcleanup() { syscall(SYS_UNLINK, _bpath); return 0; }

fn work_tokenize() { sql_tokenize("INSERT INTO users VALUES (42, 'hello world')"); return 0; }
fn work_parse_insert() { sql_tokenize("INSERT INTO users VALUES (42, 'hello world')"); sql_parse(); return 0; }
fn work_parse_select() { sql_tokenize("SELECT * FROM users"); sql_parse(); return 0; }
fn work_parse_create() { sql_tokenize("CREATE TABLE t (id INT, name STR, age INT)"); sql_parse(); return 0; }
fn work_parse_where() { sql_tokenize("SELECT * FROM t WHERE age > 25 AND id < 100"); sql_parse(); return 0; }
fn work_parse_update() { sql_tokenize("UPDATE t SET age = 31 WHERE name = 'alice'"); sql_parse(); return 0; }

fn main() {
    alloc_init();
    fl_init();
    patra_init();

    var benches = vec_new();
    var N = 10000;
    var ri = 0;

    # --- SQL parsing ---

    var b1 = bench_new("sql_tokenize");
    bench_run(b1, &work_tokenize, N);
    vec_push(benches, b1);

    var b2 = bench_new("parse_insert");
    bench_run(b2, &work_parse_insert, N);
    vec_push(benches, b2);

    var b3 = bench_new("parse_select");
    bench_run(b3, &work_parse_select, N);
    vec_push(benches, b3);

    var b4 = bench_new("parse_where");
    bench_run(b4, &work_parse_where, N);
    vec_push(benches, b4);

    var b5 = bench_new("parse_update");
    bench_run(b5, &work_parse_update, N);
    vec_push(benches, b5);

    # --- Row encoding ---

    var b6 = bench_new("row_encode_2col");
    var schema = fl_alloc(PAGE_SIZE);
    memset(schema, 0, PAGE_SIZE);
    store64(schema + SCH_NCOLS, 2);
    store64(schema + SCH_START + 0 * SCH_ENTRY_SZ + SCH_CTYPE, COL_INT);
    store64(schema + SCH_START + 1 * SCH_ENTRY_SZ + SCH_CTYPE, COL_STR);
    var rsz = row_compute_size(schema, 2);
    var row = fl_alloc(rsz);
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b6);
        var bi = 0;
        while (bi < 10000) {
            memset(row, 0, rsz);
            row_write_int(row, 0, bi);
            row_write_str(row, 8, "bench", 5);
            bi = bi + 1;
        }
        bench_batch_stop(b6, 10000);
        ri = ri + 1;
    }
    vec_push(benches, b6);
    fl_free(row);
    fl_free(schema);

    # --- Page alloc ---

    _bcleanup();
    var b7 = bench_new("page_alloc_1k");
    var fd = _pt_file_create(_bpath);
    var hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);
    bench_batch_start(b7);
    for (var i = 0; i < 1000; i = i + 1) { page_alloc(fd, hdr); }
    bench_batch_stop(b7, 1000);
    vec_push(benches, b7);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
    _bcleanup();

    # --- INSERT 1K ---

    _bcleanup();
    var b8 = bench_new("insert_1k");
    _bdb = patra_open(_bpath);
    patra_exec(_bdb, "CREATE TABLE bench (id INT, val STR)");
    bench_batch_start(b8);
    for (var i = 0; i < 1000; i = i + 1) {
        patra_exec(_bdb, "INSERT INTO bench VALUES (1, 'data')");
    }
    bench_batch_stop(b8, 1000);
    vec_push(benches, b8);

    # --- SELECT * 1K rows ---

    var b9 = bench_new("select_1k");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b9);
        var rs = patra_query(_bdb, "SELECT * FROM bench");
        bench_batch_stop(b9, 1);
        patra_result_free(rs);
        ri = ri + 1;
    }
    vec_push(benches, b9);

    # --- SELECT with WHERE ---

    var b10 = bench_new("select_where_1k");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b10);
        var rs = patra_query(_bdb, "SELECT * FROM bench WHERE id = 1");
        bench_batch_stop(b10, 1);
        patra_result_free(rs);
        ri = ri + 1;
    }
    vec_push(benches, b10);

    # --- UPDATE with WHERE ---

    var b11 = bench_new("update_where");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b11);
        patra_exec(_bdb, "UPDATE bench SET val = 'upd' WHERE id = 1");
        bench_batch_stop(b11, 1);
        ri = ri + 1;
    }
    vec_push(benches, b11);

    # --- DELETE (small set) ---

    patra_close(_bdb);
    _bcleanup();
    var b12 = bench_new("delete_50");
    _bdb = patra_open(_bpath);
    patra_exec(_bdb, "CREATE TABLE del (id INT)");
    for (var i = 0; i < 50; i = i + 1) {
        patra_exec(_bdb, "INSERT INTO del VALUES (1)");
    }
    bench_batch_start(b12);
    patra_exec(_bdb, "DELETE FROM del");
    bench_batch_stop(b12, 1);
    vec_push(benches, b12);

    patra_close(_bdb);
    _bcleanup();

    # --- Full roundtrip ---

    var b13 = bench_new("roundtrip");
    ri = 0;
    while (ri < 100) {
        _bcleanup();
        bench_batch_start(b13);
        var db = patra_open(_bpath);
        patra_exec(db, "CREATE TABLE t (x INT)");
        patra_exec(db, "INSERT INTO t VALUES (1)");
        patra_exec(db, "INSERT INTO t VALUES (2)");
        var rs = patra_query(db, "SELECT * FROM t WHERE x = 1");
        patra_result_free(rs);
        patra_exec(db, "UPDATE t SET x = 3 WHERE x = 2");
        patra_exec(db, "DELETE FROM t WHERE x = 1");
        patra_close(db);
        bench_batch_stop(b13, 1);
        ri = ri + 1;
    }
    vec_push(benches, b13);
    _bcleanup();

    # --- JSONL append ---

    var _jbpath = "/tmp/patra_bench.jsonl";
    syscall(SYS_UNLINK, _jbpath);
    var b14 = bench_new("jsonl_append_1k");
    var jfd = jsonl_open(_jbpath);
    bench_batch_start(b14);
    for (var ji = 0; ji < 1000; ji = ji + 1) {
        jsonl_append(jfd, "{\"i\": 1}", 8);
    }
    bench_batch_stop(b14, 1000);
    vec_push(benches, b14);

    # --- JSONL read 1K ---

    var b15 = bench_new("jsonl_read_1k");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b15);
        var lr = jsonl_read(jfd);
        bench_batch_stop(b15, 1);
        jsonl_lines_free(lr);
        ri = ri + 1;
    }
    vec_push(benches, b15);
    jsonl_close(jfd);
    syscall(SYS_UNLINK, _jbpath);

    # --- B-tree insert ---

    _bcleanup();
    var b16 = bench_new("btree_insert_1k");
    fd = _pt_file_create(_bpath);
    hdr = fl_alloc(PAGE_SIZE);
    patra_hdr_read(fd, hdr);
    var bt_root = btree_create(fd, hdr);
    bench_batch_start(b16);
    for (var bi = 0; bi < 1000; bi = bi + 1) {
        bt_root = btree_insert(fd, hdr, bt_root, bi, bi);
    }
    bench_batch_stop(b16, 1000);
    vec_push(benches, b16);

    # --- B-tree search ---

    var b17 = bench_new("btree_search_1k");
    var bout = fl_alloc(64);
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b17);
        for (var si = 0; si < 1000; si = si + 1) {
            btree_search(fd, bt_root, si, bout, 8);
        }
        bench_batch_stop(b17, 1000);
        ri = ri + 1;
    }
    vec_push(benches, b17);
    fl_free(bout);
    fl_free(hdr);
    syscall(SYS_CLOSE, fd);
    _bcleanup();

    # --- Indexed SELECT vs full scan ---

    _bcleanup();
    _bdb = patra_open(_bpath);
    patra_exec(_bdb, "CREATE TABLE idx (id INT, val STR)");
    for (var ii = 0; ii < 500; ii = ii + 1) {
        patra_exec(_bdb, "INSERT INTO idx VALUES (1, 'x')");
    }

    var b18 = bench_new("select_idx_eq_500");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b18);
        var rs = patra_query(_bdb, "SELECT * FROM idx WHERE id = 1");
        bench_batch_stop(b18, 1);
        patra_result_free(rs);
        ri = ri + 1;
    }
    vec_push(benches, b18);

    var b19 = bench_new("select_scan_500");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b19);
        var rs = patra_query(_bdb, "SELECT * FROM idx");
        bench_batch_stop(b19, 1);
        patra_result_free(rs);
        ri = ri + 1;
    }
    vec_push(benches, b19);
    patra_close(_bdb);
    _bcleanup();

    # --- ORDER BY ---

    _bcleanup();
    _bdb = patra_open(_bpath);
    patra_exec(_bdb, "CREATE TABLE srt (id INT, x INT)");
    for (var oi = 0; oi < 200; oi = oi + 1) {
        patra_exec(_bdb, "INSERT INTO srt VALUES (1, 0)");
    }
    var b20 = bench_new("order_by_200");
    ri = 0;
    while (ri < 100) {
        bench_batch_start(b20);
        var rs = patra_query(_bdb, "SELECT * FROM srt ORDER BY id");
        bench_batch_stop(b20, 1);
        patra_result_free(rs);
        ri = ri + 1;
    }
    vec_push(benches, b20);
    patra_close(_bdb);
    _bcleanup();

    bench_report_all(benches);
    return 0;
}

var r = main();
syscall(SYS_EXIT, r);
